{
	"$schema": "https://emdashcms.com/schemas/emdash-plugin.schema.json",

	"slug": "awcms-micro-sikesra",
	"version": "0.1.1",
	"license": "LicenseRef-AW-NC-1.0",
	"publisher": "ahliweb.co.id",
	"author": { "name": "AWCMS-Micro / AhliWeb" },
	// Add `security` and `repo` when the final standalone package location is known.
	"name": "AWCMS-Micro SIKESRA Plugin",
	"description": "SIKESRA welfare and social-religious registry plugin for AWCMS-Micro, including region-scoped registry data, verification workflow, documents, import/export, RBAC/ABAC, audit, and public-safe aggregate reporting.",
	"keywords": ["awcms-micro", "sikesra", "emdash", "plugin", "tenant-ready"],

	// Keep this trust contract aligned with the real runtime surface before release.
	"capabilities": ["content:read", "content:write", "media:read", "media:write", "users:read"],
	"allowedHosts": [],
	"storage": {
		"sikesra_access_change_events": {
			"indexes": ["timestamp", "kind", "scope", ["kind", "timestamp"]],
		},
		"sikesra_abac_change_events": {
			"indexes": ["timestamp", "kind", "scope", ["kind", "timestamp"]],
		},
		"sikesra_registry_entities": {
			"indexes": ["code", "entityType", "sensitivity", ["entityType", "sensitivity"]],
		},
		"sikesra_abac_attribute_catalog": {
			"indexes": ["key", "targetType", "updatedAt", ["targetType", "updatedAt"]],
		},
		"sikesra_abac_policy_rules": {
			"indexes": ["id", "effect", "updatedAt", ["effect", "updatedAt"]],
		},
		"sikesra_supporting_documents": {
			"indexes": [
				"registryEntityId",
				"documentType",
				"sensitivity",
				["registryEntityId", "sensitivity"],
			],
		},
		"sikesra_verification_stage_state": {
			"indexes": ["registryEntityId", "stage", "updatedAt", ["registryEntityId", "updatedAt"]],
		},
		"sikesra_abac_resource_assignments": {
			"indexes": ["resourceId", "updatedAt"],
		},
		"sikesra_abac_subject_assignments": {
			"indexes": ["subjectId", "updatedAt"],
		},
		"sikesra_content_snapshots": {
			"indexes": [
				"collection",
				"contentId",
				"timestamp",
				["collection", "timestamp"],
				["contentId", "timestamp"],
			],
		},
		"sikesra_settings_state": {
			"indexes": ["key", "updatedAt"],
		},
		"sikesra_plugin_state": {
			"indexes": ["key", "updatedAt"],
		},
		"sikesra_permission_catalog": {
			"indexes": ["slug", "scope", "updatedAt", ["scope", "updatedAt"]],
		},
		"sikesra_role_catalog": {
			"indexes": ["slug", "updatedAt"],
		},
		"sikesra_role_permission_assignments": {
			"indexes": ["roleSlug", "updatedAt"],
		},
		"sikesra_user_role_assignments": {
			"indexes": ["userId", "updatedAt"],
		},
		"sikesra_verification_events": {
			"indexes": ["registryEntityId", "stage", "createdAt", ["registryEntityId", "createdAt"]],
		},
	},

	"admin": {
		"pages": [
			{ "path": "/overview", "label": "Overview", "icon": "stack" },
			{ "path": "/registry", "label": "Registry", "icon": "grid" },
			{ "path": "/registry/new", "label": "Create Registry Record", "icon": "plus" },
			{ "path": "/registry/:id", "label": "Registry Detail", "icon": "file" },
			{ "path": "/documents", "label": "Documents", "icon": "file" },
			{ "path": "/import", "label": "Import", "icon": "arrow-up-from-bracket" },
			{ "path": "/verification", "label": "Verification", "icon": "check" },
			{ "path": "/reports", "label": "Reports", "icon": "chart" },
			{ "path": "/audit", "label": "Audit", "icon": "list" },
			{ "path": "/access/users", "label": "Users", "icon": "users" },
			{ "path": "/access/permissions", "label": "Permissions", "icon": "lock" },
			{ "path": "/access/roles", "label": "Roles", "icon": "users" },
			{ "path": "/access/matrix", "label": "Role Matrix", "icon": "grid" },
			{ "path": "/access/scopes", "label": "Scopes", "icon": "globe" },
			{ "path": "/access/preview", "label": "Access Preview", "icon": "eye" },
			{ "path": "/abac/attributes", "label": "ABAC Attributes", "icon": "sliders" },
			{ "path": "/abac/policies", "label": "ABAC Policies", "icon": "shield" },
			{ "path": "/abac/preview", "label": "ABAC Preview", "icon": "target" },
			{ "path": "/regions", "label": "Regions", "icon": "globe" },
			{ "path": "/data-types", "label": "Data Types", "icon": "list" },
			{ "path": "/field-standards", "label": "Field Standards", "icon": "list" },
			{
				"path": "/custom-attributes/definitions",
				"label": "Custom Attribute Definitions",
				"icon": "sliders",
			},
			{
				"path": "/custom-attributes/values",
				"label": "Custom Attribute Values",
				"icon": "sliders",
			},
			{ "path": "/delete-requests", "label": "Delete Requests", "icon": "trash" },
			{ "path": "/archives", "label": "Archives", "icon": "archive" },
			{ "path": "/settings", "label": "Settings", "icon": "gear" },
		],
		"widgets": [
			{ "id": "governance-status", "title": "Governance Status", "size": "half" },
			{ "id": "access-rights-health", "title": "Access Rights Health", "size": "half" },
			{ "id": "abac-policy-status", "title": "ABAC Policy Status", "size": "half" },
		],
	},
}
