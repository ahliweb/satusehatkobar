{
	"name": "@awcms-micro/plugin-sikesra",
	"version": "0.1.2",
	"description": "AWCMS-Micro SIKESRA plugin for EmDash-compatible projects",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./admin": {
			"types": "./dist/admin.d.ts",
			"import": "./dist/admin.js",
			"default": "./dist/admin.js"
		},
		"./navigation": {
			"types": "./dist/navigation.d.ts",
			"import": "./dist/navigation.js",
			"default": "./dist/navigation.js"
		},
		"./sandbox": {
			"types": "./dist/sandbox.d.ts",
			"import": "./dist/sandbox.js",
			"default": "./dist/sandbox.js"
		}
	},
	"files": [
		"dist",
		"emdash-plugin.jsonc",
		"migrations",
		"seeds",
		"src/locales",
		"docs",
		"README.md"
	],
	"keywords": [
		"awcms-micro",
		"sikesra",
		"emdash",
		"plugin",
		"tenant-ready"
	],
	"license": "SEE LICENSE IN LICENSE.md",
	"peerDependencies": {
		"@cloudflare/kumo": "catalog:",
		"emdash": "workspace:*",
		"react": "^18.0.0 || ^19.0.0"
	},
	"dependencies": {
		"@lingui/react": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/kumo": "catalog:",
		"@types/node": "24.10.13",
		"@types/react": "^19.2.14",
		"emdash": "workspace:*",
		"tsdown": "^0.20.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"scripts": {
		"awcms:sikesra:check-boundary": "node scripts/check-boundary.mjs",
		"awcms:sikesra:check-d1-prefix": "vitest run tests/migration-prefix.test.ts",
		"awcms:sikesra:check-data-boundary": "node scripts/check-data-boundary.mjs",
		"awcms:sikesra:check-destructive-migrations": "node scripts/check-destructive-migrations.mjs",
		"awcms:sikesra:check-user-references": "node scripts/check-user-references.mjs",
		"awcms:sikesra:check-file-links": "node scripts/check-file-links.mjs",
		"awcms:sikesra:check-seeds": "node scripts/check-seeds.mjs",
		"awcms:sikesra:check-routes": "vitest run tests/plugin.test.ts -t 'registers required SIKESRA plugin routes|uses GET for SIKESRA admin read APIs'",
		"awcms:sikesra:check-admin-pages": "vitest run tests/plugin.test.ts -t 'declares admin pages'",
		"awcms:sikesra:backup-inventory": "node scripts/backup-inventory.mjs",
		"awcms:sikesra:validate-data-after-rebuild": "node scripts/validate-data-after-rebuild.mjs",
		"awcms:sikesra:validate-after-emdash-sync": "pnpm awcms:sikesra:check-boundary && pnpm awcms:sikesra:check-d1-prefix && pnpm awcms:sikesra:check-data-boundary && pnpm awcms:sikesra:check-destructive-migrations && pnpm awcms:sikesra:check-user-references && pnpm awcms:sikesra:check-file-links && pnpm awcms:sikesra:check-seeds && pnpm awcms:sikesra:check-routes && pnpm awcms:sikesra:check-admin-pages && pnpm typecheck && pnpm test && pnpm build",
		"build": "tsdown",
		"dev": "tsdown --watch",
		"prepare": "node --run build",
		"prepublishOnly": "node --run build",
		"test": "vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"engines": {
		"node": ">=22"
	}
}
