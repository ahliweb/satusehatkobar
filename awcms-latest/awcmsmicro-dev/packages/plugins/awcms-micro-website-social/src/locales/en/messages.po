msgid "websiteSocial.label"
msgstr "Website Social"

msgid "websiteSocial.eyebrow"
msgstr "Website social"

msgid "websiteSocial.title"
msgstr "Website Social Contact"

msgid "websiteSocial.description"
msgstr "Manage WhatsApp number, contextual call-to-action labels, and public contact messages through the EmDash website_social collection. Public templates read the latest published locale record and render sticky WhatsApp buttons plus section-specific public CTAs."

msgid "websiteSocial.manage"
msgstr "Manage WhatsApp settings"

msgid "websiteSocial.viewPublic"
msgstr "View public website"

msgid "websiteSocial.tipPhone"
msgstr "Use E.164 style phone numbers without plus signs, for example 6289513380400."

msgid "websiteSocial.tipSafety"
msgstr "Keep messages public-safe and avoid personal, sensitive, or operational secrets."

msgid "websiteSocial.tipLocale"
msgstr "Publish one active record per locale so public pages can resolve localized CTA text."

msgid "websiteSocial.tipLabels"
msgstr "Set hero, profile, services, posts, gallery, news, widgets, contact, and sticky labels/messages so each public CTA matches its page context."
