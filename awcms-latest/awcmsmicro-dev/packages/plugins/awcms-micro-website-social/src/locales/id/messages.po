msgid "websiteSocial.label"
msgstr "Sosial Website"

msgid "websiteSocial.eyebrow"
msgstr "Sosial website"

msgid "websiteSocial.title"
msgstr "Kontak Sosial Website"

msgid "websiteSocial.description"
msgstr "Kelola nomor WhatsApp, label ajakan bertindak kontekstual, dan pesan kontak publik melalui koleksi website_social EmDash. Template publik membaca record locale terbaru yang dipublikasikan dan merender tombol WhatsApp sticky serta CTA publik khusus section."

msgid "websiteSocial.manage"
msgstr "Kelola pengaturan WhatsApp"

msgid "websiteSocial.viewPublic"
msgstr "Lihat website publik"

msgid "websiteSocial.tipPhone"
msgstr "Gunakan nomor telepon gaya E.164 tanpa tanda plus, misalnya 6289513380400."

msgid "websiteSocial.tipSafety"
msgstr "Jaga pesan tetap aman untuk publik dan hindari rahasia personal, sensitif, atau operasional."

msgid "websiteSocial.tipLocale"
msgstr "Publikasikan satu record aktif per locale agar halaman publik dapat memakai teks CTA terlokalisasi."

msgid "websiteSocial.tipLabels"
msgstr "Atur label/pesan hero, profil, layanan, pos, galeri, berita, widget, kontak, dan sticky agar setiap CTA publik sesuai konteks halamannya."
