msgctxt "gallery.error.itemObject"
msgid "Item {index} must be an object"
msgstr "Item {index} harus berupa objek"

msgctxt "gallery.error.itemType"
msgid "Item {index} type must be image or video"
msgstr "Tipe item {index} harus image atau video"

msgctxt "gallery.error.itemSrc"
msgid "Item {index} must use a public EmDash media URL or HTTPS URL"
msgstr "Item {index} harus menggunakan URL media EmDash publik atau URL HTTPS"

msgctxt "gallery.error.imageMime"
msgid "Item {index} image MIME type must start with image/"
msgstr "MIME type gambar item {index} harus diawali image/"

msgctxt "gallery.error.videoMime"
msgid "Item {index} video MIME type must start with video/"
msgstr "MIME type video item {index} harus diawali video/"

msgctxt "gallery.error.imageSize"
msgid "Item {index} image exceeds the {limit} byte limit"
msgstr "Gambar item {index} melebihi batas {limit} byte"

msgctxt "gallery.error.videoSize"
msgid "Item {index} video exceeds the {limit} byte limit"
msgstr "Video item {index} melebihi batas {limit} byte"

msgctxt "gallery.error.imageAlt"
msgid "Item {index} image requires alt text"
msgstr "Gambar item {index} memerlukan teks alt"

msgctxt "gallery.error.videoCaption"
msgid "Item {index} video requires a caption"
msgstr "Video item {index} memerlukan caption"

msgctxt "gallery.error.contentObject"
msgid "Gallery content must be an object"
msgstr "Konten galeri harus berupa objek"

msgctxt "gallery.error.titleRequired"
msgid "Gallery title is required"
msgstr "Judul galeri wajib diisi"

msgctxt "gallery.error.typeInvalid"
msgid "Gallery type must be photo, video, or mixed"
msgstr "Tipe galeri harus photo, video, atau mixed"

msgctxt "gallery.error.layoutInvalid"
msgid "Layout variant must be grid, masonry, carousel, or slider"
msgstr "Variant layout harus grid, masonry, carousel, atau slider"

msgctxt "gallery.error.itemsArray"
msgid "Gallery items must be an array"
msgstr "Item galeri harus berupa array"

