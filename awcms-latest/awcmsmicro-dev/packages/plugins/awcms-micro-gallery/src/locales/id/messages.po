msgctxt "gallery.title"
msgid "AWCMS-Micro Gallery"
msgstr "Galeri AWCMS-Micro"

msgctxt "gallery.desc"
msgid "Manage gallery validation, Cloudflare media flags, and audit-ready gallery controls without changing EmDash core."
msgstr "Kelola validasi galeri, bendera media Cloudflare, dan kontrol galeri siap-audit tanpa mengubah core EmDash."

msgctxt "gallery.saved"
msgid "Gallery settings saved."
msgstr "Pengaturan galeri disimpan."

msgctxt "gallery.settings"
msgid "Settings"
msgstr "Pengaturan"

msgctxt "gallery.media"
msgid "Media"
msgstr "Media"

msgctxt "gallery.images"
msgid "Images"
msgstr "Gambar"

msgctxt "gallery.videos"
msgid "Videos"
msgstr "Video"

msgctxt "gallery.cf_images"
msgid "Cloudflare Images"
msgstr "Gambar Cloudflare"

msgctxt "gallery.cf_stream"
msgid "Cloudflare Stream"
msgstr "Stream Cloudflare"

msgctxt "gallery.max_img"
msgid "Maximum image bytes"
msgstr "Ukuran gambar maksimum (byte)"

msgctxt "gallery.max_img_desc"
msgid "Images larger than this are rejected by gallery validation routes and hooks."
msgstr "Gambar yang lebih besar dari batas ini akan ditolak oleh route dan hook validasi galeri."

msgctxt "gallery.max_vid"
msgid "Maximum video bytes"
msgstr "Ukuran video maksimum (byte)"

msgctxt "gallery.max_vid_desc"
msgid "Videos larger than this are rejected by gallery validation routes and hooks."
msgstr "Video yang lebih besar dari batas ini akan ditolak oleh route dan hook validasi galeri."

msgctxt "gallery.cf_images_enable"
msgid "Cloudflare Images enabled"
msgstr "Gambar Cloudflare diaktifkan"

msgctxt "gallery.cf_images_enable_desc"
msgid "Enable Cloudflare Images support for gallery media workflows."
msgstr "Aktifkan dukungan Cloudflare Images untuk alur kerja media galeri."

msgctxt "gallery.cf_stream_enable"
msgid "Cloudflare Stream enabled"
msgstr "Stream Cloudflare diaktifkan"

msgctxt "gallery.cf_stream_enable_desc"
msgid "Enable Cloudflare Stream support for gallery media workflows."
msgstr "Aktifkan dukungan Cloudflare Stream untuk alur kerja media galeri."

