---
/**
 * Portfolio card for the /portfolio index and homepage portfolio teaser.
 * Content is CMS-sourced (portfolio collection); category labels are localized
 * here via a fixed bilingual map (the collection stores a stable category code).
 */
interface Props {
	title: string;
	category?: string | null;
	tech?: unknown;
	url?: string | null;
	locale: string;
	visitLabel: string;
	inDevLabel: string;
}
const { title, category, tech, url, locale, visitLabel, inDevLabel } = Astro.props;
const isId = locale?.startsWith("id");

const CATEGORY_LABELS: Record<string, { en: string; id: string }> = {
	education: { en: "Education", id: "Pendidikan" },
	tech: { en: "Technology", id: "Teknologi" },
	foundation: { en: "Foundation & Conservation", id: "Yayasan & Konservasi" },
	government: { en: "Government", id: "Pemerintahan" },
	training: { en: "Training", id: "Pelatihan" },
	tax: { en: "Tax Services", id: "Layanan Pajak" },
	health: { en: "Health", id: "Kesehatan" },
	tourism: { en: "Tourism", id: "Pariwisata" },
	media: { en: "Media & News", id: "Media & Berita" },
	ecommerce: { en: "E-commerce", id: "E-commerce" },
	transport: { en: "Transport & Tour", id: "Transportasi & Tur" },
	mobile: { en: "Mobile App", id: "Aplikasi Mobile" },
	property: { en: "Property", id: "Properti" },
	hospital: { en: "Hospital Website", id: "Website Rumah Sakit" },
};

const WWW_RE = /^www\./;
const catKey = typeof category === "string" ? category : "";
const catLabel = CATEGORY_LABELS[catKey] ? (isId ? CATEGORY_LABELS[catKey].id : CATEGORY_LABELS[catKey].en) : catKey;
const techList = Array.isArray(tech) ? (tech as string[]) : [];
const host = (() => {
	if (!url) return "";
	try {
		return new URL(url).hostname.replace(WWW_RE, "");
	} catch {
		return "";
	}
})();
---
<article class="portfolio-card">
	{catLabel && <span class="portfolio-card__cat">{catLabel}</span>}
	<h3 class="portfolio-card__title">{title}</h3>
	{techList.length > 0 && (
		<div class="portfolio-card__tech">
			{techList.map((tag) => <span class="portfolio-tag">{tag}</span>)}
		</div>
	)}
	<div class="portfolio-card__foot">
		{url ? (
			<a class="portfolio-card__visit" href={url} target="_blank" rel="noopener noreferrer">
				{visitLabel}
				<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
			</a>
		) : (
			<span class="portfolio-card__badge">{inDevLabel}</span>
		)}
		{host && url && <span class="portfolio-tag">{host}</span>}
	</div>
</article>
