---
/**
 * Service card for the homepage services grid and the services index.
 * Content is CMS-sourced (services collection); this is presentation only.
 */
interface Props {
	href: string;
	icon?: string;
	title: string;
	description?: string | null;
	moreLabel?: string | null;
}
const { href, icon = "✨", title, description, moreLabel } = Astro.props;
---
<a class="service-card" href={href} data-astro-prefetch="hover">
	<span class="service-card__icon" aria-hidden="true">{icon}</span>
	<h3 class="service-card__title">{title}</h3>
	{description && <p class="service-card__desc">{description}</p>}
	{moreLabel && (
		<span class="service-card__more">
			{moreLabel}
			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
		</span>
	)}
</a>
