---
import { getMenu } from "emdash";
import PublicNavigationItem from "./PublicNavigationItem.astro";
import { resolvePublicNavigationItems } from "./public-navigation";

interface Props {
	name?: string;
}

const { name = "primary" } = Astro.props;
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || "en";
let menu = await getMenu(name, { locale: currentLocale });

// Fallback logic to check other standard menu names if the requested one is empty/not found
if (!menu?.items.length) {
	const fallbackName = name === "primary" ? "header" : "primary";
	const fallbackMenu = await getMenu(fallbackName, { locale: currentLocale });
	if (fallbackMenu?.items.length) {
		menu = fallbackMenu;
	}
}

const navLabel = currentLocale.startsWith("id") ? "Navigasi utama" : "Primary navigation";

if (menu?.items.length) {
	menu.items = await resolvePublicNavigationItems(menu.items, menu.name || name, currentLocale, async (menuName, locale) => {
		const subMenu = await getMenu(menuName, { locale });
		return subMenu?.items.length ? subMenu.items : undefined;
	});
}
---

{menu?.items.length ? (
	<nav class="awcms-public-nav" aria-label={navLabel}>
		<ul class="awcms-public-nav__list">
			{menu.items.map((item) => (
				<PublicNavigationItem item={item} currentPath={Astro.url.pathname} currentLocale={currentLocale || menu.locale} level={0} />
			))}
		</ul>
	</nav>
) : null}

<style is:global>
	.awcms-public-nav {
		width: 100%;
	}

	.awcms-public-nav__list,
	.awcms-public-nav__submenu {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.awcms-public-nav__list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: flex-start;
	}

	.awcms-public-nav__item {
		position: relative;
	}

	.awcms-public-nav__link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.5rem 0.875rem;
		border-radius: 0.5rem;
		border: 1px solid transparent;
		color: var(--text-main);
		text-decoration: none;
		line-height: 1.2;
		font-weight: 500;
		position: relative;
		transition: background-color 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
		            border-color 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
		            color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* Bottom indicator for active level-0 menu items */
	.level-0 {
		position: relative;
	}

	.level-0 > .awcms-public-nav__link::after {
		content: "";
		position: absolute;
		bottom: -2px;
		left: 0.875rem;
		right: 0.875rem;
		height: 2px;
		background: var(--gradient-primary);
		border-radius: 2px;
		transform: scaleX(0);
		transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
		transform-origin: center;
	}

	.level-0:hover > .awcms-public-nav__link::after,
	.level-0 > .awcms-public-nav__link:focus-visible::after,
	.level-0 > .awcms-public-nav__link[aria-current="page"]::after,
	.level-0.is-active > .awcms-public-nav__link::after {
		transform: scaleX(1);
	}

	.level-0 > .awcms-public-nav__link:hover,
	.level-0 > .awcms-public-nav__link:focus-visible {
		background: rgba(99, 102, 241, 0.08);
		color: var(--accent-hover);
		outline: none;
	}

	.level-0 > .awcms-public-nav__link[aria-current="page"],
	.level-0.is-active > .awcms-public-nav__link {
		background: rgba(99, 102, 241, 0.05);
		color: var(--accent);
		font-weight: 600;
	}

	.awcms-public-nav__chevron {
		width: 0.75rem;
		height: 0.75rem;
		opacity: 0.7;
		flex-shrink: 0;
		transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.awcms-public-nav__item:hover > .awcms-public-nav__link .awcms-public-nav__chevron,
	.awcms-public-nav__item:focus-within > .awcms-public-nav__link .awcms-public-nav__chevron {
		transform: rotate(180deg);
		opacity: 1;
		color: var(--accent);
	}

	.awcms-public-nav__submenu {
		display: none;
		position: absolute;
		inset-block-start: calc(100% + 0.5rem);
		inset-inline-start: 0;
		min-width: 16rem;
		padding: 0.5rem;
		border: 1px solid var(--surface-border);
		border-radius: var(--radius-md);
		background: var(--surface-main);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: var(--shadow-xl);
		z-index: 20;
		animation: navFadeIn 0.2s cubic-bezier(0.16, 1, 0.3, 1);
	}

	@keyframes navFadeIn {
		from {
			opacity: 0;
			transform: translateY(4px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Invisible bridge to prevent hover loss when crossing gaps */
	.awcms-public-nav__submenu::before {
		content: "";
		position: absolute;
		inset-block-start: -1rem;
		inset-inline-start: 0;
		inset-inline-end: 0;
		height: 1rem;
		z-index: -1;
	}

	.awcms-public-nav__submenu .awcms-public-nav__submenu {
		inset-block-start: 0;
		inset-inline-start: calc(100% + 0.5rem);
	}

	.awcms-public-nav__item:hover > .awcms-public-nav__submenu,
	.awcms-public-nav__item:focus-within > .awcms-public-nav__submenu {
		display: block;
	}

	.awcms-public-nav__submenu .awcms-public-nav__link {
		display: flex;
		width: 100%;
		justify-content: space-between;
		border-radius: var(--radius-sm);
		padding: 0.6rem 0.85rem;
		font-weight: 500;
	}

	.awcms-public-nav__submenu .awcms-public-nav__link:hover,
	.awcms-public-nav__submenu .awcms-public-nav__link:focus-visible {
		background: rgba(99, 102, 241, 0.08);
		color: var(--accent-hover);
		outline: none;
	}

	/* Subtle left border accent to active submenu items */
	.awcms-public-nav__submenu .awcms-public-nav__item.is-active > .awcms-public-nav__link {
		background: rgba(99, 102, 241, 0.05);
		border-left: 3px solid var(--accent);
		border-top-left-radius: 0;
		border-bottom-left-radius: 0;
		font-weight: 600;
		color: var(--accent);
	}

	.awcms-public-nav__submenu .awcms-public-nav__item + .awcms-public-nav__item {
		margin-block-start: 0.25rem;
	}

	.awcms-public-nav__item.has-children > .awcms-public-nav__link {
		padding-inline-end: 0.7rem;
	}

	@media (max-width: 48rem) {
		.awcms-public-nav__list {
			flex-direction: column;
			align-items: stretch;
		}

		.awcms-public-nav__item {
			width: 100%;
		}

		.awcms-public-nav__link {
			width: 100%;
			justify-content: space-between;
			border-radius: var(--radius-sm);
		}

		.level-0 > .awcms-public-nav__link::after {
			display: none; /* Hide bottom line on mobile */
		}

		.awcms-public-nav__submenu {
			position: static;
			display: block; /* Always show submenus on mobile */
			min-width: 0;
			margin-block-start: 0.25rem;
			padding: 0;
			padding-inline-start: 1rem;
			box-shadow: none;
			background: transparent;
			border: none;
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
			animation: none;
		}

		.awcms-public-nav__submenu::before {
			display: none;
		}

		.awcms-public-nav__submenu .awcms-public-nav__submenu {
			margin-inline-start: 1rem;
		}
	}
</style>

<script>
	const itemsWithChildren = document.querySelectorAll('.awcms-public-nav__item.has-children');
	itemsWithChildren.forEach(item => {
		const link = item.querySelector('.awcms-public-nav__link');
		if (!link) return;

		const showSubmenu = () => link.setAttribute('aria-expanded', 'true');
		const hideSubmenu = () => link.setAttribute('aria-expanded', 'false');

		item.addEventListener('mouseenter', showSubmenu);
		item.addEventListener('mouseleave', hideSubmenu);
		item.addEventListener('focusin', showSubmenu);
		item.addEventListener('focusout', (e) => {
			const focusEvent = e as FocusEvent;
			if (!item.contains(focusEvent.relatedTarget as Node)) {
				hideSubmenu();
			}
		});
	});
</script>
