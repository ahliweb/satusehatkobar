---
import { decodeSlug, getEmDashEntry, getI18nConfig, getSeoMeta, getSiteSettings } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { toLocalePath } from "../../utils/locale-path";
import { resolveAwcmsMicroSiteIdentity } from "../../utils/site-identity";
import { getPublicCopy } from "../../utils/public-copy";

function asString(value: unknown) {
	return typeof value === "string" ? value : String(value ?? "");
}

const slug = decodeSlug(Astro.params.slug);

if (!slug) return Astro.rewrite("/404");

const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;

const { entry: service, cacheHint } = await getEmDashEntry("services", slug, { locale: currentLocale });

if (!service) return Astro.rewrite("/404");

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getPublicCopy(currentLocale);
const { siteTitle } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const seo = getSeoMeta(service, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: toLocalePath(`/services/${slug}`, currentLocale, localeOptions),
});
const icon = asString(service.data.icon);
const description = asString(service.data.description);
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	image={seo.ogImage}
	content={{ collection: "services", id: asString(service.data.id), slug }}
	showFooterWidgets={false}
>
	<article class="service-detail">
		<a class="service-detail__back" href={toLocalePath("/services", currentLocale, localeOptions)} data-astro-prefetch="hover">
			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
			{copy.servicesBackToList}
		</a>
		<header class="service-detail__header">
			{icon && <span class="service-card__icon" aria-hidden="true">{icon}</span>}
			<h1 {...service.edit.title}>{service.data.title}</h1>
			{description && <p class="service-detail__lead">{description}</p>}
		</header>
		<div class="service-detail__body">
			<PortableText value={service.data.content} />
		</div>
	</article>
</Base>

<style>
	.service-detail {
		max-width: 52rem;
		margin-inline: auto;
	}
	.service-detail__back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}
	.service-detail__back:hover {
		color: var(--accent);
	}
	.service-detail__header {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--surface-border);
	}
	.service-detail__header h1 {
		font-size: clamp(1.9rem, 4vw, 2.6rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0;
	}
	.service-detail__lead {
		font-size: 1.1rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.6;
	}
	.service-detail__body :global(h2) {
		font-family: "Outfit", "Inter", system-ui, sans-serif;
		font-size: 1.5rem;
		margin: 2rem 0 0.85rem;
	}
	.service-detail__body :global(h3) {
		font-size: 1.18rem;
		margin: 1.5rem 0 0.6rem;
	}
	.service-detail__body :global(p) {
		line-height: 1.75;
		margin: 0 0 1rem;
	}
	.service-detail__body :global(ul) {
		padding-inline-start: 1.25rem;
		line-height: 1.75;
	}
	.service-detail__body :global(li) {
		margin-bottom: 0.4rem;
	}
</style>
