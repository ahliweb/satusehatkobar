---
import { getEmDashCollection, getI18nConfig, getSiteSettings } from "emdash";
import { Image, WidgetArea } from "emdash/ui";
import Base from "../layouts/Base.astro";
import SectionHeading from "../components/public/SectionHeading.astro";
import ServiceCard from "../components/public/ServiceCard.astro";
import PortfolioCard from "../components/public/PortfolioCard.astro";
import TestimonialCard from "../components/public/TestimonialCard.astro";
import { resolveEntrySlug, toLocalePath } from "../utils/locale-path";
import { getPublicCopy } from "../utils/public-copy";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";
import { createWhatsAppUrl, getWebsiteSocialConfig } from "../utils/website-social";

function asImage(value: unknown) {
	return value as any;
}

function textPreview(value: unknown, fallback = "") {
	if (typeof value === "string") return value;
	return fallback;
}

interface GalleryEntry {
	id: string;
	slug: string;
	status: string;
	locale?: string;
	translationOf?: string;
	data: {
		slug?: string;
		title: string;
		description?: string;
		gallery_type: "photo" | "video" | "mixed";
		layout_variant: "grid" | "masonry" | "carousel" | "slider";
		event_date?: string;
		location?: string;
		featured?: boolean;
		cover_image?: { src: string; alt?: string } | null;
		gallery_items?: Array<{
			type: "image" | "video";
			src: string;
			alt?: string;
			caption?: string;
			poster?: string;
		}>;
	};
}

const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;

const [
	{ entries: posts, cacheHint: postsCacheHint },
	{ entries: newsItems, cacheHint: newsCacheHint },
	{ entries: pages, cacheHint: pagesCacheHint },
	{ entries: rawGalleries, cacheHint: galleriesCacheHint },
	{ entries: rawServices, cacheHint: servicesCacheHint },
	{ entries: rawPortfolio, cacheHint: portfolioCacheHint },
	{ entries: rawTestimonials, cacheHint: testimonialsCacheHint },
] = await Promise.all([
	getEmDashCollection("posts", { orderBy: { published_at: "desc" }, limit: 6, locale: currentLocale }),
	getEmDashCollection("news", { orderBy: { published_at: "desc" }, limit: 4, locale: currentLocale }),
	getEmDashCollection("pages", { orderBy: { published_at: "desc" }, limit: 12, locale: currentLocale }),
	getEmDashCollection("galleries", { orderBy: { published_at: "desc" }, limit: 12, locale: currentLocale }),
	getEmDashCollection("services", { orderBy: { published_at: "desc" }, limit: 12, locale: currentLocale }),
	getEmDashCollection("portfolio", { orderBy: { published_at: "desc" }, limit: 60, locale: currentLocale }),
	getEmDashCollection("testimonials", { orderBy: { published_at: "desc" }, limit: 12, locale: currentLocale }),
]);

if (Astro.cache?.enabled) {
	Astro.cache.set(postsCacheHint);
	Astro.cache.set(newsCacheHint);
	Astro.cache.set(pagesCacheHint);
	Astro.cache.set(galleriesCacheHint);
	Astro.cache.set(servicesCacheHint);
	Astro.cache.set(portfolioCacheHint);
	Astro.cache.set(testimonialsCacheHint);
}

interface TestimonialEntry {
	id: string;
	slug: string;
	data: { quote: string; name?: string; role?: string; featured?: boolean; order?: number };
}
const featuredTestimonials = (rawTestimonials as unknown as TestimonialEntry[])
	.toSorted((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
	.slice(0, 3);

interface PortfolioEntry {
	id: string;
	slug: string;
	data: { title: string; category?: string; tech?: unknown; url?: string; stage?: string; featured?: boolean; order?: number };
}
const featuredPortfolio = (rawPortfolio as unknown as PortfolioEntry[])
	.toSorted((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
	.filter((item) => item.data.featured)
	.slice(0, 6);

interface ServiceEntry {
	id: string;
	slug: string;
	data: { slug?: string; title: string; description?: string; icon?: string; order?: number };
}
const services = (rawServices as unknown as ServiceEntry[])
	.toSorted((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const featuredServices = services.slice(0, 6);

const galleries = rawGalleries as unknown as GalleryEntry[];
const { siteTitle, siteTagline } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const localeOptions = { defaultLocale, locales: i18nConfig?.locales || ["en", "id"] };
const copy = getPublicCopy(currentLocale);
const websiteSocial = await getWebsiteSocialConfig(currentLocale);

const findPage = (slug: string) => pages.find((page) => resolveEntrySlug(page) === slug);
const profilePage = findPage("about") ?? pages[0];
const featuredPosts = posts.slice(0, 3);
const featuredNews = newsItems.slice(0, 3);
const featuredGalleries = galleries.filter((gallery) => gallery.data.featured).slice(0, 3);
const visibleGalleries = featuredGalleries.length > 0 ? featuredGalleries : galleries.slice(0, 3);
const mediaShowcaseItems = visibleGalleries
	.flatMap((gallery) => {
		const galleryHref = toLocalePath(`/gallery/${resolveEntrySlug(gallery)}`, currentLocale, localeOptions);
		const galleryItems = Array.isArray(gallery.data.gallery_items) ? gallery.data.gallery_items : [];
		if (galleryItems.length > 0) {
			return galleryItems.slice(0, 4).map((item) => ({
				...item,
				galleryTitle: gallery.data.title,
				href: galleryHref,
				previewSrc: item.type === "video" ? item.poster || gallery.data.cover_image?.src : item.src,
			}));
		}

		return gallery.data.cover_image
			? [
					{
						type: "image" as const,
						src: gallery.data.cover_image.src,
						alt: gallery.data.cover_image.alt || gallery.data.title,
						caption: gallery.data.description,
						galleryTitle: gallery.data.title,
						href: galleryHref,
						previewSrc: gallery.data.cover_image.src,
					},
				]
			: [];
	})
	.slice(0, 8);
const publicCounts = [
	{ label: copy.counts.posts, value: posts.length },
	{ label: copy.counts.news, value: newsItems.length },
	{ label: copy.counts.pages, value: pages.length },
	{ label: copy.counts.galleries, value: galleries.length },
];
const heroPrimaryHref = toLocalePath("/posts", currentLocale, localeOptions);
const heroSecondaryHref = toLocalePath("/gallery", currentLocale, localeOptions);
const showWhatsAppCta = websiteSocial.enabled && Boolean(websiteSocial.whatsappNumber);
const heroWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.heroMessage);
const contactWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.contactMessage);
const profileWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.profileMessage);
const servicesWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.servicesMessage);
const postsWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.postsMessage);
const galleryWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.galleryMessage);
const newsWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.newsMessage);
const widgetsWhatsAppHref = createWhatsAppUrl(websiteSocial, websiteSocial.widgetsMessage);

const storageBaseUrl = import.meta.env.AWCMS_MICRO_STORAGE_PUBLIC_BASE_URL
	|| import.meta.env.CLOUDFLARE_WORKER_STORAGE_PUBLIC_BASE_URL
	|| (typeof process !== "undefined" ? process.env.AWCMS_MICRO_STORAGE_PUBLIC_BASE_URL : undefined)
	|| (typeof process !== "undefined" ? process.env.CLOUDFLARE_WORKER_STORAGE_PUBLIC_BASE_URL : undefined)
	|| (Astro.locals as any).runtime?.env?.AWCMS_MICRO_STORAGE_PUBLIC_BASE_URL
	|| (Astro.locals as any).runtime?.env?.CLOUDFLARE_WORKER_STORAGE_PUBLIC_BASE_URL
	|| null;

const dashboardMockupUrl = storageBaseUrl ? `${storageBaseUrl}/dashboard_mockup.png` : "/dashboard_mockup.png";
const networkShowcaseUrl = storageBaseUrl ? `${storageBaseUrl}/network_showcase.png` : "/network_showcase.png";
---

<Base title={siteTitle} description={siteTagline} showFooterWidgets={false}>
	<section class="landing-hero">
		<div class="landing-hero__glow" aria-hidden="true"></div>
		<div class="landing-hero__copy">
			<p class="landing-eyebrow">{copy.homeKicker}</p>
			<h1>{copy.heroTitle}</h1>
			<p>{copy.heroSubtitle}</p>
			<div class="landing-actions">
				{showWhatsAppCta && (
					<a class="landing-button landing-button--whatsapp" href={heroWhatsAppHref} target="_blank" rel="noopener noreferrer">
						{websiteSocial.heroLabel}
					</a>
				)}
				<a class="landing-button landing-button--primary" href={heroPrimaryHref} data-astro-prefetch="hover">
					{copy.landingExploreContent}
				</a>
				<a class="landing-button landing-button--secondary" href={heroSecondaryHref} data-astro-prefetch="hover">
					{copy.landingViewMedia}
				</a>
			</div>
			<div class="landing-stats" aria-label={copy.landingContentStats}>
				{publicCounts.map((item) => (
					<div>
						<strong>{item.value}</strong>
						<span>{item.label}</span>
					</div>
				))}
			</div>
		</div>
		<div class="landing-hero__visual reveal-scale">
			<div class="hero-mockup-wrapper">
				<img src={dashboardMockupUrl} alt="AWCMS Micro Developer Dashboard" class="hero-mockup-image" loading="eager" onerror="this.onerror=null;this.src='/dashboard_mockup.png'" />
				<div class="hero-mockup-glow"></div>
			</div>
		</div>
	</section>

	<section class="landing-split reveal">
		<div class="landing-split__copy">
			<p class="landing-eyebrow">{copy.landingProfileEyebrow}</p>
			<h2>{profilePage?.data.title ?? siteTitle}</h2>
			<p class="landing-lead">{siteTagline}</p>
			<p class="landing-muted">{copy.landingProfileDescription}</p>
			<div class="landing-inline-actions">
				{profilePage && (
					<a class="landing-text-link" href={toLocalePath(`/${resolveEntrySlug(profilePage)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
						{copy.openPage}
					</a>
				)}
				{showWhatsAppCta && (
					<a class="landing-text-link landing-text-link--whatsapp" href={profileWhatsAppHref} target="_blank" rel="noopener noreferrer">
						{websiteSocial.profileLabel}
					</a>
				)}
			</div>
		</div>
		<div class="landing-split__visual reveal-scale">
			<div class="split-image-wrapper">
				<img src={networkShowcaseUrl} alt="Cloudflare Edge Network Showcase" class="split-image" loading="lazy" onerror="this.onerror=null;this.src='/network_showcase.png'" />
				<div class="split-image-glow"></div>
			</div>
		</div>
	</section>

	<section class="section-shell reveal">
		<SectionHeading eyebrow={copy.servicesKicker} title={copy.servicesSectionHeading} subtitle={copy.servicesSectionSubtitle}>
			<Fragment slot="actions">
				{showWhatsAppCta && (
					<a class="landing-button landing-button--whatsapp" href={servicesWhatsAppHref} target="_blank" rel="noopener noreferrer">
						{websiteSocial.servicesLabel}
					</a>
				)}
				<a class="landing-button landing-button--secondary" href={toLocalePath("/services", currentLocale, localeOptions)} data-astro-prefetch="hover">
					{copy.servicesViewAll}
				</a>
			</Fragment>
		</SectionHeading>
		{featuredServices.length === 0 ? (
			<p class="section-subtitle">{copy.servicesEmpty}</p>
		) : (
			<div class="public-grid public-grid--3">
				{featuredServices.map((service) => (
					<ServiceCard
						href={toLocalePath(`/services/${resolveEntrySlug(service)}`, currentLocale, localeOptions)}
						icon={service.data.icon}
						title={service.data.title}
						description={service.data.description}
						moreLabel={copy.servicesLearnMore}
					/>
				))}
			</div>
		)}
	</section>

	{featuredPortfolio.length > 0 && (
		<section class="section-shell reveal">
			<SectionHeading eyebrow={copy.portfolioKicker} title={copy.portfolioSectionHeading} subtitle={copy.portfolioSectionSubtitle}>
				<Fragment slot="actions">
					<a class="landing-button landing-button--secondary" href={toLocalePath("/portfolio", currentLocale, localeOptions)} data-astro-prefetch="hover">
						{copy.portfolioViewAll}
					</a>
				</Fragment>
			</SectionHeading>
			<div class="public-grid public-grid--3">
				{featuredPortfolio.map((item) => (
					<PortfolioCard
						title={item.data.title}
						category={item.data.category}
						tech={item.data.tech}
						url={item.data.url}
						locale={currentLocale}
						visitLabel={copy.portfolioVisit}
						inDevLabel={copy.portfolioInDevBadge}
					/>
				))}
			</div>
		</section>
	)}

	<section class="landing-section landing-section--dark reveal">
		<div class="landing-section__heading landing-section__heading--inline">
			<div>
				<p class="landing-eyebrow">{copy.postsTitle}</p>
				<h2>{copy.landingPortfolioHeading}</h2>
			</div>
			<div class="landing-section-actions">
				{showWhatsAppCta && (
					<a class="landing-button landing-button--whatsapp" href={postsWhatsAppHref} target="_blank" rel="noopener noreferrer">
						{websiteSocial.postsLabel}
					</a>
				)}
				<a class="landing-button landing-button--secondary" href={toLocalePath("/posts", currentLocale, localeOptions)} data-astro-prefetch="hover">
					{copy.viewPosts}
				</a>
			</div>
		</div>
		<div class="landing-slider-row">
			{featuredPosts.length === 0 ? (
				<p class="landing-empty">{copy.noPostsYet}</p>
			) : (
				featuredPosts.map((post, index) => (
					<article class="landing-content-card">
						<a href={toLocalePath(`/posts/${resolveEntrySlug(post)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
							<span class="landing-number">0{index + 1}</span>
							{post.data.featured_image && <Image image={asImage(post.data.featured_image)} class="landing-content-card__image" />}
							<h3>{post.data.title}</h3>
						</a>
						{post.data.excerpt && <p>{post.data.excerpt}</p>}
					</article>
				))
			)}
		</div>
	</section>

	<section class="landing-section reveal">
		<div class="landing-section__heading landing-section__heading--inline">
			<div>
				<p class="landing-eyebrow">{copy.galleryKicker}</p>
				<h2>{copy.galleryListHeading}</h2>
			</div>
			<div class="landing-section-actions">
				{showWhatsAppCta && (
					<a class="landing-button landing-button--whatsapp" href={galleryWhatsAppHref} target="_blank" rel="noopener noreferrer">
						{websiteSocial.galleryLabel}
					</a>
				)}
				<a class="landing-button landing-button--secondary" href={toLocalePath("/gallery", currentLocale, localeOptions)} data-astro-prefetch="hover">
					{copy.galleryViewAll}
				</a>
			</div>
		</div>
		<div class="landing-media-grid">
			{visibleGalleries.length === 0 ? (
				<p class="landing-empty">{copy.noGalleryYet}</p>
			) : (
				visibleGalleries.map((gallery) => {
					const itemCount = Array.isArray(gallery.data.gallery_items) ? gallery.data.gallery_items.length : 0;
					return (
						<a class="landing-media-card" href={toLocalePath(`/gallery/${resolveEntrySlug(gallery)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
							<div class="landing-media-card__cover">
								{gallery.data.cover_image ? (
									<Image image={asImage(gallery.data.cover_image)} class="landing-media-card__image" alt={gallery.data.title} />
								) : (
									<span>{gallery.data.gallery_type === "video" ? "Video" : "Gallery"}</span>
								)}
							</div>
							<div>
								<span>{copy.galleryItemsCount(itemCount)}</span>
								<h3>{gallery.data.title}</h3>
								{gallery.data.description && <p>{gallery.data.description}</p>}
							</div>
						</a>
					);
				})
			)}
		</div>
	</section>

	<section class="landing-section landing-media-showcase reveal" aria-label={copy.landingMediaShowcaseHeading}>
		<div class="landing-section__heading landing-section__heading--inline">
			<div>
				<p class="landing-eyebrow">{copy.landingMediaShowcaseEyebrow}</p>
				<h2>{copy.landingMediaShowcaseHeading}</h2>
				<p class="landing-muted">{copy.landingMediaShowcaseIntro}</p>
			</div>
			<a class="landing-button landing-button--secondary" href={toLocalePath("/gallery", currentLocale, localeOptions)} data-astro-prefetch="hover">
				{copy.galleryViewAll}
			</a>
		</div>
		<div class="landing-media-strip" role="list" aria-label={copy.landingMediaShowcaseHeading}>
			{mediaShowcaseItems.length === 0 ? (
				<p class="landing-empty">{copy.noGalleryYet}</p>
			) : (
				mediaShowcaseItems.map((item, index) => (
					<article class="landing-media-tile" role="listitem">
						<a href={item.href} data-astro-prefetch="hover" aria-label={`${copy.openPage}: ${item.galleryTitle}`}>
							{item.previewSrc ? (
								<img src={item.previewSrc} alt={item.alt || item.caption || item.galleryTitle} loading="lazy" decoding="async" />
							) : (
								<span>{item.type === "video" ? copy.galleryVideoLabel : copy.galleryPhotoLabel}</span>
							)}
						</a>
						<details class="landing-media-detail">
							<summary>{copy.landingMediaOpenDetails}</summary>
							<strong>{item.galleryTitle}</strong>
							<p>{item.caption || item.alt || copy.galleryItemsCount(index + 1)}</p>
						</details>
					</article>
				))
			)}
		</div>
	</section>

	<section class="landing-split landing-split--faq reveal">
		<div>
			<p class="landing-eyebrow">{copy.newsTitle}</p>
			<h2>{copy.landingUpdatesHeading}</h2>
		</div>
		<div class="landing-update-list">
			{featuredNews.length === 0 ? (
				<p class="landing-empty">{copy.noNewsYet}</p>
			) : (
				featuredNews.map((item) => (
					<a href={toLocalePath(`/news/${resolveEntrySlug(item)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
						<strong>{item.data.title}</strong>
						<p>{textPreview(item.data.summary, copy.newsWorkflowVisible)}</p>
					</a>
				))
			)}
		</div>
		{showWhatsAppCta && (
			<a class="landing-text-link landing-text-link--whatsapp" href={newsWhatsAppHref} target="_blank" rel="noopener noreferrer">
				{websiteSocial.newsLabel}
			</a>
		)}
	</section>

	{featuredTestimonials.length > 0 && (
		<section class="section-shell reveal">
			<SectionHeading eyebrow={copy.testimonialsKicker} title={copy.testimonialsSectionHeading} subtitle={copy.testimonialsSectionSubtitle}>
				<Fragment slot="actions">
					<a class="landing-button landing-button--secondary" href={toLocalePath("/testimonials", currentLocale, localeOptions)} data-astro-prefetch="hover">
						{copy.testimonialsTitle}
					</a>
				</Fragment>
			</SectionHeading>
			<div class="public-grid public-grid--3">
				{featuredTestimonials.map((item) => (
					<TestimonialCard quote={item.data.quote} name={item.data.name || ""} role={item.data.role} />
				))}
			</div>
		</section>
	)}

	<section class="landing-section landing-section--steps reveal">
		<div class="landing-section__heading">
			<p class="landing-eyebrow">{copy.landingOrderStepsEyebrow}</p>
			<h2>{copy.landingOrderStepsHeading}</h2>
		</div>
		<div class="landing-steps-grid">
			{copy.landingOrderSteps.map(([num, title, desc]) => (
				<div class="landing-step-card">
					<span class="landing-step-num">{num}</span>
					<h3>{title}</h3>
					<p>{desc}</p>
				</div>
			))}
		</div>
	</section>

	<section class="landing-split landing-split--faq reveal">
		<div>
			<p class="landing-eyebrow">{copy.landingFaqEyebrow}</p>
			<h2>{copy.landingFaqHeading}</h2>
		</div>
		<div class="landing-faq-list">
			{copy.landingFaqItems.map(([question, answer]) => (
				<details class="landing-faq-item">
					<summary>
						<span>{question}</span>
						<svg class="landing-faq-chevron" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<polyline points="6 9 12 15 18 9"/>
						</svg>
					</summary>
					<div class="landing-faq-content">
						<p>{answer}</p>
					</div>
				</details>
			))}
		</div>
	</section>

	<section class="landing-contact reveal">
		<p class="landing-eyebrow">{copy.landingContactEyebrow}</p>
		<h2>{copy.ctaTitle}</h2>
		<p>{copy.ctaSubtitle}</p>
		<div class="landing-contact-cards" aria-label={copy.landingContactCardsLabel}>
			<div class="landing-contact-card landing-contact-card--map">
				<span>{copy.landingContactMapCard}</span>
				<strong>{siteTitle}</strong>
				<p>{copy.landingContactMapHint}</p>
			</div>
			<div class="landing-contact-card">
				<span>{copy.landingContactContentCard}</span>
				<strong>{copy.landingPagesPostsGallery}</strong>
				<p>{copy.landingAdminContentHint}</p>
			</div>
			{showWhatsAppCta && (
				<div class="landing-contact-card">
					<span>{copy.landingContactWhatsAppCard}</span>
					<strong>+{websiteSocial.whatsappNumber}</strong>
					<p>{websiteSocial.contactLabel}</p>
				</div>
			)}
		</div>
		<div class="landing-actions">
			{showWhatsAppCta && (
				<a class="landing-button landing-button--whatsapp" href={contactWhatsAppHref} target="_blank" rel="noopener noreferrer">
					{websiteSocial.contactLabel}
				</a>
			)}
			<a class="landing-button landing-button--primary" href="/_emdash/admin/content/pages">{copy.managePagesInAdmin}</a>
			<a class="landing-button landing-button--secondary" href={toLocalePath("/gallery", currentLocale, localeOptions)} data-astro-prefetch="hover">{copy.galleryViewAll}</a>
		</div>
	</section>

	<section class="landing-section landing-widgets reveal" aria-label={copy.landingManagedWidgets}>
		<div class="landing-section__heading landing-section__heading--inline">
			<div>
				<p class="landing-eyebrow">{copy.landingWidgetsEyebrow}</p>
				<h2>{copy.landingManagedWidgets}</h2>
			</div>
			<div class="landing-section-actions">
				{showWhatsAppCta && (
					<a class="landing-button landing-button--whatsapp" href={widgetsWhatsAppHref} target="_blank" rel="noopener noreferrer">
						{websiteSocial.widgetsLabel}
					</a>
				)}
				<a class="landing-button landing-button--secondary" href="/_emdash/admin/widgets">
					{copy.landingManageWidgets}
				</a>
			</div>
		</div>
		<WidgetArea name="homepage" />
	</section>
</Base>

<style>
	.landing-hero,
	.landing-split,
	.landing-section,
	.landing-contact {
		position: relative;
		overflow: hidden;
		border-radius: 2rem;
		border: 1px solid var(--surface-border);
		background: var(--gradient-surface);
		box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
	}

