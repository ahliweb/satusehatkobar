---
import { getI18nConfig, getSiteSettings } from "emdash";
import { createPublicPageContext } from "emdash/page";
import { EmDashBodyEnd, EmDashBodyStart, EmDashHead, WidgetArea } from "emdash/ui";
import LiveSearch from "emdash/ui/search";
import PromoPopup from "../components/PromoPopup.astro";
import PublicNavigation from "../components/PublicNavigation.astro";
import LanguageSwitcher from "../components/public/LanguageSwitcher.astro";
import WhatsAppFloatingCta from "../components/WhatsAppFloatingCta.astro";
import { toLocalePath } from "../utils/locale-path";
import { getPublicCopy } from "../utils/public-copy";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";
import { getWebsiteSocialConfig } from "../utils/website-social";
import "../styles/public.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
	showFooterWidgets?: boolean;
}

const { title, pageTitle, description, image, canonical, content, showFooterWidgets = true } = Astro.props;
const siteSettings = await getSiteSettings();
const { siteTitle, siteTagline, siteLogo, hasCustomLogo, hasCustomFavicon } = resolveAwcmsMicroSiteIdentity(siteSettings);
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const websiteSocial = await getWebsiteSocialConfig(currentLocale);
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getPublicCopy(currentLocale);
const currentYear = new Date().getFullYear();
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;
const pageDescription = description ?? siteTagline;
const hasCmsOgImage = !!siteSettings?.seo?.defaultOgImage?.url;
const fallbackOgImageUrl = (image || hasCmsOgImage) ? null : new URL("/og-image.png", Astro.url.origin).toString();
const effectiveImage = image || fallbackOgImageUrl;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: content?.collection === "news" ? "news" : "website",
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description: pageDescription,
	canonical: canonical || Astro.url.href,
	image: effectiveImage,
	content,
	siteName: siteTitle,
});

const businessJsonLd = websiteSocial.schemaType
	? JSON.stringify({
			"@context": "https://schema.org",
			"@type": websiteSocial.schemaType || "Organization",
			...(websiteSocial.businessName ? { name: websiteSocial.businessName } : { name: siteTitle }),
			...(websiteSocial.businessDescription && { description: websiteSocial.businessDescription }),
			url: Astro.url.origin,
			...(websiteSocial.businessPhone
				? { telephone: `+${websiteSocial.businessPhone}` }
				: websiteSocial.whatsappNumber
					? { telephone: `+${websiteSocial.whatsappNumber}` }
					: {}),
			...(websiteSocial.businessAddress && {
				address: { "@type": "PostalAddress", streetAddress: websiteSocial.businessAddress },
			}),
			...(websiteSocial.openingHours && { openingHours: websiteSocial.openingHours }),
			...(websiteSocial.googleMapsUrl && { hasMap: websiteSocial.googleMapsUrl }),
			...(websiteSocial.priceRange && { priceRange: websiteSocial.priceRange }),
	  })
	: null;
---

<!doctype html>
<html lang={currentLocale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		{pageDescription && <meta name="description" content={pageDescription} />}
		{canonical && <link rel="canonical" href={canonical} />}
		{!hasCustomFavicon && <link rel="icon" type="image/png" href="/awcms-logo.png" />}
		<meta name="twitter:card" content="summary_large_image" />
		<EmDashHead page={pageCtx} />
		{businessJsonLd && <script is:inline type="application/ld+json" set:html={businessJsonLd} />}
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
		<style>
			:root {
				color-scheme: light;
				font-family: 'Inter', system-ui, sans-serif;
				--bg-main: #ffffff;
				--surface-main: #f8fafc;
				--surface-border: rgba(14, 165, 233, 0.15);
				--text-main: #0f172a;
				--text-muted: #475569;
				--accent: #0ea5e9;
				--accent-hover: #0284c7;
				--gradient-primary: linear-gradient(135deg, #0ea5e9, #6366f1);
				--gradient-surface: linear-gradient(180deg, #ffffff, #f1f5f9);

				/* EmDash LiveSearch Variables */
				--emdash-search-bg: var(--surface-main);
				--emdash-search-text: var(--text-main);
				--emdash-search-muted: var(--text-muted);
				--emdash-search-border: var(--surface-border);
				--emdash-search-border-focus: var(--accent);
				--emdash-search-hover: var(--surface-border);
				--emdash-search-highlight: var(--accent);
			}

			:root.dark {
				color-scheme: dark;
				--bg-main: #0a0e17;
				--surface-main: rgba(15, 23, 42, 0.6);
				--surface-border: rgba(125, 211, 252, 0.1);
				--text-main: #f8fafc;
				--text-muted: #94a3b8;
				--accent: #38bdf8;
				--accent-hover: #7dd3fc;
				--gradient-surface: linear-gradient(180deg, rgba(15, 23, 42, 0.8), rgba(15, 23, 42, 0.4));
			}

			body {
				margin: 0;
				background: var(--bg-main);
				background-image: 
					radial-gradient(circle at 15% 50%, rgba(14, 165, 233, 0.08) 0%, transparent 40%),
					radial-gradient(circle at 85% 30%, rgba(99, 102, 241, 0.08) 0%, transparent 40%);
				color: var(--text-main);
				line-height: 1.6;
			}

			h1, h2, h3, h4, .brand {
				font-family: 'Outfit', 'Inter', system-ui, sans-serif;
			}

			a {
				color: var(--accent);
				text-decoration: none;
				transition: color 0.2s ease, text-shadow 0.2s ease;
			}

			a:hover {
				color: var(--accent-hover);
				text-shadow: 0 0 12px rgba(56, 189, 248, 0.4);
			}

			.main {
				max-width: 1200px;
				margin: 0 auto;
				padding-inline: 1.5rem;
				padding-block: 3rem 6rem;
			}

			input, button, .widget-search__input {
				background: var(--surface-main);
				color: var(--text-main);
				border: 1px solid var(--surface-border);
				border-radius: 0.5rem;
				padding: 0.5rem 0.75rem;
			}

			.widget-recent-posts__link, .awcms-public-nav__link {
				color: var(--text-main);
			}

			.awcms-public-nav__link:hover {
				color: var(--accent-hover);
			}

			.card {
				background: var(--gradient-surface);
				border: 1px solid var(--surface-border);
				border-radius: 1.25rem;
				padding: 1.5rem;
				backdrop-filter: blur(8px);
				transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
			}

			/* Make sure live search input in header looks modern */
			.site-header-nav .emdash-live-search {
				position: relative;
				width: 100%;
				max-width: 240px;
			}
			.site-header-nav .emdash-live-search-input {
				width: 100%;
				font-size: 0.875rem;
				padding: 0.5rem 1.25rem 0.5rem 2.25rem;
				border-radius: 999px;
				background: rgba(99, 102, 241, 0.05);
				border: 1px solid var(--surface-border);
				transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
				color: var(--text-main);
			}
			.site-header-nav .emdash-live-search-input:focus {
				background: var(--surface-main);
				border-color: var(--accent);
				box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
				outline: none;
				transform: scale(1.02);
			}
			.site-header-nav .emdash-live-search-results {
				top: calc(100% + 8px) !important;
				border-radius: 1.25rem !important;
				border: 1px solid var(--surface-border) !important;
				box-shadow: 0 16px 32px rgba(99, 102, 241, 0.08) !important;
				background: var(--surface-main) !important;
				backdrop-filter: blur(16px);
			}

			/* Header Styles */
			.site-header-nav {
				position: sticky;
				top: 0;
				z-index: 100;
				background: rgba(255, 255, 255, 0.75);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border-bottom: 1px solid var(--surface-border);
				transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
			}

			.site-header-nav.scrolled {
				background: rgba(255, 255, 255, 0.92);
				box-shadow: 0 4px 24px rgba(99, 102, 241, 0.10);
				border-bottom-color: rgba(99, 102, 241, 0.22);
			}

			:root.dark .site-header-nav {
				background: rgba(10, 14, 23, 0.75);
			}

			:root.dark .site-header-nav.scrolled {
				background: rgba(10, 14, 23, 0.92);
				box-shadow: 0 4px 24px rgba(99, 102, 241, 0.16);
			}

			.nav-container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0.85rem 1.5rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				position: relative;
			}

			.nav-brand {
				display: flex;
				align-items: center;
				gap: 0.625rem;
				text-decoration: none;
				flex-shrink: 0;
			}

			.brand-logo {
				height: 36px;
				width: auto;
				display: block;
			}

			.brand-text {
				font-weight: 800;
				font-size: 1.35rem;
				background: var(--gradient-primary);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				letter-spacing: -0.02em;
			}

			.menu-toggle-checkbox {
				display: none;
			}

			.menu-toggle-label {
				display: none;
				flex-direction: column;
				justify-content: space-between;
				width: 22px;
				height: 16px;
				cursor: pointer;
				z-index: 110;
			}

			.hamburger-bar {
				width: 100%;
				height: 2px;
				background-color: var(--text-main);
				border-radius: 2px;
				transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
				transform-origin: center;
			}

			.nav-menu {
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-grow: 1;
				margin-left: 2.5rem;
			}

			.nav-center {
				display: flex;
				align-items: center;
			}

			.nav-right {
				display: flex;
				align-items: center;
				gap: 1.25rem;
				margin-left: auto;
			}

			.header-hours-badge {
				display: none;
				align-items: center;
				gap: 0.4rem;
				font-size: 0.72rem;
				font-weight: 600;
				color: var(--text-muted);
				background: rgba(99, 102, 241, 0.06);
				border: 1px solid var(--surface-border);
				padding: 0.3rem 0.75rem;
				border-radius: 999px;
				white-space: nowrap;
			}

			@media (min-width: 769px) {
				.header-hours-badge {
					display: inline-flex;
				}
			}

			.header-hours-dot {
				width: 0.5rem;
				height: 0.5rem;
				border-radius: 50%;
				background: #22c55e;
				animation: pulse-dot 2s ease-in-out infinite;
				flex-shrink: 0;
			}

			@keyframes pulse-dot {
				0%, 100% { opacity: 1; transform: scale(1); }
				50% { opacity: 0.6; transform: scale(0.85); }
			}

			.header-search {
				display: flex;
				align-items: center;
			}

			.nav-actions {
				display: flex;
				align-items: center;
				gap: 0.75rem;
			}

			/* Admin Login Button */
			.admin-login-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				font-size: 0.83rem;
				font-weight: 700;
				color: var(--text-main);
				background: rgba(99, 102, 241, 0.07);
				border: 1px solid var(--surface-border);
				padding: 0.45rem 1.05rem 0.45rem 0.85rem;
				border-radius: 999px;
				transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
				text-decoration: none;
				letter-spacing: 0.01em;
				white-space: nowrap;
			}

			.admin-login-icon {
				flex-shrink: 0;
				transition: transform 0.25s ease;
			}

			.admin-login-btn:hover {
				background: var(--gradient-primary);
				color: #ffffff;
				border-color: transparent;
				box-shadow: 0 4px 18px rgba(99, 102, 241, 0.28);
				transform: translateY(-1px);
			}

			.admin-login-btn:hover .admin-login-icon {
				transform: translateX(2px);
			}

			.theme-toggle-btn {
				padding: 0.5rem;
				font-size: 1.15rem;
				background: transparent;
				border: none;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 50%;
				transition: background-color 0.25s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
				color: var(--text-main);
			}

			.theme-toggle-btn:hover {
				background: rgba(99, 102, 241, 0.1);
				transform: rotate(20deg) scale(1.1);
			}

			/* Footer Styles */
			.site-footer {
				background: var(--surface-main);
				border-top: 1px solid var(--surface-border);
				transition: all 0.3s ease;
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				position: relative;
				overflow: hidden;
			}

			.footer-accent-bar {
				height: 3px;
				background: var(--gradient-primary);
				opacity: 0.7;
			}

			.site-footer::before {
				content: "";
				position: absolute;
				bottom: 0;
				left: 50%;
				transform: translateX(-50%);
				width: 60%;
				height: 300px;
				background: radial-gradient(ellipse at center bottom, rgba(99, 102, 241, 0.06), transparent 70%);
				pointer-events: none;
				z-index: 0;
			}

			.footer-inner {
				position: relative;
				z-index: 1;
				padding: 4rem 1.5rem 2.5rem;
			}

			.footer-container {
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				justify-content: space-between;
				gap: 3rem;
				flex-wrap: wrap;
				margin-bottom: 4rem;
			}

			.footer-brand-col {
				max-width: 22rem;
				flex-shrink: 0;
			}

			.footer-brand-text {
				font-weight: 800;
				font-size: 1.35rem;
				background: var(--gradient-primary);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				letter-spacing: -0.02em;
				display: inline-block;
				margin-bottom: 0.85rem;
			}

			.footer-brand-desc {
				font-size: 0.95rem;
				line-height: 1.6;
				color: var(--text-muted);
				margin: 0 0 1.5rem;
			}

			.footer-brand-badges {
				display: flex;
				gap: 0.65rem;
				flex-wrap: wrap;
			}

			.footer-badge-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				font-size: 0.8rem;
				font-weight: 600;
				color: var(--text-muted);
				background: rgba(99, 102, 241, 0.06);
				border: 1px solid var(--surface-border);
				padding: 0.35rem 0.85rem;
				border-radius: 999px;
				text-decoration: none;
				transition: all 0.22s ease;
			}

			.footer-badge-link:hover {
				color: var(--accent);
				border-color: var(--accent);
				background: rgba(99, 102, 241, 0.1);
				transform: translateY(-1px);
				box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
			}

			.footer-badge-link--ahliweb:hover {
				color: #0ea5e9;
				border-color: #0ea5e9;
				background: rgba(14, 165, 233, 0.08);
				box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
			}

			.footer-badge-icon {
				flex-shrink: 0;
			}

			.footer-links-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(120px, 1fr));
				gap: 2rem;
				flex-grow: 1;
				max-width: 38rem;
			}

			.footer-links-title {
				font-size: 0.8rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.09em;
				color: var(--text-main);
				margin: 0 0 1.25rem;
			}

			.footer-links-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.footer-links-list a {
				font-size: 0.9rem;
				color: var(--text-muted);
				text-decoration: none;
				transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
				display: inline-flex;
				align-items: center;
				gap: 0.3rem;
			}

			.footer-links-list a:hover {
				color: var(--accent);
				transform: translateX(5px);
			}

			.footer-admin-link {
				color: var(--text-muted) !important;
				opacity: 0.75;
			}

			.footer-admin-link:hover {
				color: var(--accent) !important;
				opacity: 1;
			}

			.footer-location-section {
				max-width: 1200px;
				margin: 0 auto 3rem;
				padding: 2rem;
				background: rgba(99, 102, 241, 0.03);
				border: 1px solid var(--surface-border);
				border-radius: 1.25rem;
			}

			.footer-location-heading {
				font-size: 0.8rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.09em;
				color: var(--text-main);
				margin: 0 0 1.25rem;
			}

			.footer-location-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5rem;
				align-items: start;
			}

			.footer-map-embed {
				position: relative;
				overflow: hidden;
				border-radius: 0.875rem;
				border: 1px solid var(--surface-border);
				min-height: 200px;
			}

			.footer-map-iframe {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				border: 0;
			}

			.footer-location-info {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.footer-location-item {
				display: flex;
				align-items: flex-start;
				gap: 0.75rem;
			}

			.footer-location-icon {
				flex-shrink: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 2rem;
				height: 2rem;
				border-radius: 0.5rem;
				background: rgba(99, 102, 241, 0.08);
				color: var(--accent);
				border: 1px solid var(--surface-border);
				margin-top: 0.1rem;
			}

			.footer-location-label {
				display: block;
				font-size: 0.7rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--accent);
				margin-bottom: 0.2rem;
			}

			.footer-location-value {
				display: block;
				font-size: 0.875rem;
				color: var(--text-muted);
				line-height: 1.5;
			}

			.footer-maps-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				font-size: 0.8rem;
				font-weight: 600;
				color: var(--accent);
				background: rgba(99, 102, 241, 0.06);
				border: 1px solid var(--surface-border);
				padding: 0.45rem 1rem;
				border-radius: 999px;
				text-decoration: none;
				transition: all 0.22s ease;
				margin-top: 0.25rem;
				width: fit-content;
			}

			.footer-maps-btn:hover {
				background: rgba(99, 102, 241, 0.12);
				border-color: var(--accent);
				transform: translateY(-1px);
				box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
				text-shadow: none;
			}

			.footer-widgets-container {
				max-width: 1200px;
				margin: 0 auto 3rem;
				padding: 1.5rem;
				background: rgba(99, 102, 241, 0.02);
				border: 1px dashed var(--surface-border);
				border-radius: 1rem;
			}

			.footer-bottom {
				max-width: 1200px;
				margin: 0 auto;
				padding-top: 2rem;
				border-top: 1px solid var(--surface-border);
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 0.75rem;
			}

			.footer-copyright {
				font-size: 0.875rem;
				color: var(--text-muted);
				margin: 0;
			}

			.footer-powered {
				font-size: 0.875rem;
				color: var(--text-muted);
				margin: 0;
				display: flex;
				align-items: center;
				gap: 0.3rem;
			}

			.footer-ahliweb-link {
				font-weight: 700;
				color: var(--accent);
				text-decoration: none;
				transition: all 0.2s ease;
				position: relative;
			}

			.footer-ahliweb-link::after {
				content: "";
				position: absolute;
				bottom: -1px;
				left: 0;
				width: 0;
				height: 1px;
				background: var(--gradient-primary);
				transition: width 0.25s ease;
			}

			.footer-ahliweb-link:hover::after {
				width: 100%;
			}

			.footer-ahliweb-link:hover {
				color: var(--accent-hover);
			}

			@media (max-width: 991px) {
				.menu-toggle-label {
					display: flex;
				}

				.nav-menu {
					position: absolute;
					top: 100%;
					left: 0;
					right: 0;
					background: var(--bg-main);
					border-bottom: 1px solid var(--surface-border);
					padding: 1.5rem 1.5rem;
					flex-direction: column;
					align-items: stretch;
					gap: 1.5rem;
					margin-left: 0;
					display: none;
					box-shadow: 0 16px 32px rgba(99, 102, 241, 0.08);
					backdrop-filter: blur(16px);
				}

				.menu-toggle-checkbox:checked ~ .nav-menu {
					display: flex;
				}

				.menu-toggle-checkbox:checked ~ .menu-toggle-label .hamburger-bar:nth-child(1) {
					transform: translateY(7px) rotate(45deg);
				}

				.menu-toggle-checkbox:checked ~ .menu-toggle-label .hamburger-bar:nth-child(2) {
					opacity: 0;
					transform: scaleX(0);
				}

				.menu-toggle-checkbox:checked ~ .menu-toggle-label .hamburger-bar:nth-child(3) {
					transform: translateY(-7px) rotate(-45deg);
				}

				.nav-right {
					flex-direction: column;
					align-items: stretch;
					width: 100%;
					margin-left: 0;
					gap: 1rem;
				}

				.header-search {
					width: 100%;
				}
				
				.site-header-nav .emdash-live-search {
					max-width: none;
				}

				.nav-actions {
					justify-content: space-between;
					width: 100%;
				}

				.admin-login-btn {
					flex-grow: 1;
					justify-content: center;
				}
			}

			@media (max-width: 768px) {
				.footer-container {
					flex-direction: column;
					gap: 2.5rem;
				}

				.footer-links-grid {
					grid-template-columns: repeat(2, 1fr);
					gap: 1.5rem;
					max-width: none;
				}

				.footer-bottom {
					flex-direction: column;
					align-items: center;
					text-align: center;
				}
			}

			@media (max-width: 480px) {
				.footer-links-grid {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}
			}

			@media (max-width: 640px) {
				.footer-location-grid {
					grid-template-columns: 1fr;
				}

				.footer-map-embed {
					min-height: 180px;
				}
			}

			.card:hover {
				transform: translateY(-4px);
				border-color: rgba(56, 189, 248, 0.3);
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2), 0 0 20px rgba(56, 189, 248, 0.1);
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.75rem 1.25rem;
				border-radius: 0.75rem;
				font-weight: 600;
				font-size: 0.95rem;
				transition: all 0.2s ease;
				text-decoration: none;
				border: 1px solid transparent;
			}

			.btn-primary {
				background: var(--gradient-primary);
				color: #fff !important;
				box-shadow: 0 4px 14px rgba(14, 165, 233, 0.25);
			}

			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(14, 165, 233, 0.4);
				color: #fff !important;
				text-shadow: none;
			}

			.btn-secondary {
				background: rgba(30, 41, 59, 0.5);
				color: var(--text-main) !important;
				border: 1px solid var(--surface-border);
				backdrop-filter: blur(8px);
			}

			.btn-secondary:hover {
				background: rgba(30, 41, 59, 0.8);
				border-color: rgba(56, 189, 248, 0.3);
				transform: translateY(-2px);
				color: var(--text-main) !important;
				text-shadow: none;
			}

			/* Scroll Reveal Utility Classes */
			.reveal {
				opacity: 0;
				transform: translateY(30px);
				transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
				will-change: transform, opacity;
			}
			.reveal.active {
				opacity: 1;
				transform: translateY(0);
			}
			.reveal-fade {
				opacity: 0;
				transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1);
				will-change: opacity;
			}
			.reveal-fade.active {
				opacity: 1;
			}
			.reveal-scale {
				opacity: 0;
				transform: scale(0.95);
				transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
				will-change: transform, opacity;
			}
			.reveal-scale.active {
				opacity: 1;
				transform: scale(1);
			}

			@media (prefers-reduced-motion: reduce) {
				.reveal, .reveal-fade, .reveal-scale {
					opacity: 1 !important;
					transform: none !important;
					transition: none !important;
				}
			}
		</style>
		<script is:inline>
			(function() {
				const savedTheme = localStorage.getItem('awcms-theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="site-header-nav" id="site-header">
