---
import { createWhatsAppUrl, type WebsiteSocialConfig } from "../utils/website-social";

interface Props {
	config: WebsiteSocialConfig;
}

const { config } = Astro.props;
const href = createWhatsAppUrl(config, config.defaultMessage);
---

{config.enabled && config.whatsappNumber && (
	<a class="whatsapp-float" href={href} target="_blank" rel="noopener noreferrer" aria-label={config.stickyLabel}>
		<span class="whatsapp-float__pulse" aria-hidden="true"></span>
		<svg class="whatsapp-float__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
			<path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.34 4.95L2 22l5.29-1.39a9.84 9.84 0 0 0 4.75 1.21h.01c5.46 0 9.91-4.45 9.91-9.91S17.51 2 12.04 2Zm5.76 14.15c-.24.68-1.38 1.31-1.93 1.39-.5.08-1.13.11-1.82-.11-.42-.13-.96-.31-1.65-.61-2.9-1.25-4.79-4.17-4.94-4.36-.14-.19-1.18-1.57-1.18-3 0-1.43.75-2.13 1.01-2.42.26-.29.58-.36.77-.36h.55c.17.01.42-.06.66.5.24.58.82 2 .89 2.14.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.14-.3.29-.13.58.17.29.75 1.24 1.61 2.01 1.11.99 2.04 1.29 2.33 1.43.29.15.46.12.63-.07.19-.22.72-.84.91-1.13.19-.29.38-.24.65-.14.26.1 1.66.78 1.94.92.29.14.48.22.55.34.07.12.07.7-.17 1.38Z" />
		</svg>
		<span class="whatsapp-float__label">{config.stickyLabel}</span>
	</a>
)}

<style>
	.whatsapp-float {
		position: fixed;
		right: clamp(1rem, 3vw, 2rem);
		bottom: clamp(1rem, 3vw, 2rem);
		z-index: 50;
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 3.25rem;
		padding: 0.78rem 1.05rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
		color: #fff;
		font-weight: 800;
		box-shadow: 0 8px 24px rgba(37, 211, 102, 0.3), 0 16px 48px rgba(18, 140, 126, 0.2);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		animation: whatsapp-float-bounce 3s ease-in-out infinite;
	}

	.whatsapp-float:hover {
		color: #fff;
		background: linear-gradient(135deg, #128c7e 0%, #075e54 100%);
		transform: translateY(-5px) scale(1.05);
		box-shadow: 0 12px 30px rgba(37, 211, 102, 0.45), 0 20px 50px rgba(18, 140, 126, 0.3);
		text-shadow: none;
	}

	.whatsapp-float__pulse {
		position: absolute;
		inset: -0.35rem;
		z-index: -1;
		border-radius: inherit;
		background: rgba(37, 211, 102, 0.25);
		animation: whatsapp-pulse 2s ease-out infinite;
	}

	.whatsapp-float__icon {
		width: 1.35rem;
		height: 1.35rem;
		animation: whatsapp-wiggle 6s ease-in-out infinite;
		transform-origin: center;
		transition: transform 0.3s ease;
	}

	.whatsapp-float:hover .whatsapp-float__icon {
		transform: rotate(15deg) scale(1.1);
		animation-play-state: paused;
	}

	@keyframes whatsapp-pulse {
		0% {
			transform: scale(0.92);
			opacity: 0.8;
		}
		100% {
			transform: scale(1.22);
			opacity: 0;
		}
	}

	@keyframes whatsapp-float-bounce {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-8px);
		}
	}

	@keyframes whatsapp-wiggle {
		0%, 90%, 100% {
			transform: rotate(0);
		}
		92% {
			transform: rotate(-12deg);
		}
		94% {
			transform: rotate(12deg);
		}
		96% {
			transform: rotate(-12deg);
		}
		98% {
			transform: rotate(12deg);
		}
	}

	@media (max-width: 640px) {
		.whatsapp-float__label {
			display: none;
		}

		.whatsapp-float {
			width: 3.35rem;
			height: 3.35rem;
			justify-content: center;
			padding: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.whatsapp-float, .whatsapp-float__pulse, .whatsapp-float__icon {
			animation: none !important;
		}
		.whatsapp-float:hover {
			transform: none !important;
		}
	}
</style>
