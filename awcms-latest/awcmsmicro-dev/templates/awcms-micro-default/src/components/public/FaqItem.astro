---
/**
 * FAQ disclosure item (pure-CSS <details>/<summary>) for the homepage FAQ
 * section. Content is CMS-sourced; this is presentation only.
 */
interface Props {
	question: string;
	answer: string;
}
const { question, answer } = Astro.props;
---
<details class="faq-item">
	<summary class="faq-item__summary">{question}</summary>
	<p class="faq-item__body">{answer}</p>
</details>
