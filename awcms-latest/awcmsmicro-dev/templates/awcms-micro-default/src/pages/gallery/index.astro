---
import { getEmDashCollection, getI18nConfig } from "emdash";
import { Image } from "emdash/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveEntrySlug, toLocalePath } from "../../utils/locale-path";
import { getPublicCopy } from "../../utils/public-copy";

interface GalleryEntry {
	id: string;
	slug: string;
	status: string;
	locale?: string;
	translationOf?: string;
	data: {
		slug?: string;
		title: string;
		description?: string;
		gallery_type: "photo" | "video" | "mixed";
		layout_variant: "grid" | "masonry" | "carousel" | "slider";
		event_date?: string;
		location?: string;
		featured?: boolean;
		cover_image?: { src: string; alt?: string } | null;
		gallery_items?: Array<{
			type: "image" | "video";
			src: string;
			alt?: string;
			caption?: string;
			poster?: string;
		}>;
	};
}

function asImage(value: unknown) {
	return value as any;
}

const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;

const { entries: rawGalleries, cacheHint } = await getEmDashCollection("galleries", {
	orderBy: { published_at: "desc" },
	limit: 50,
	locale: currentLocale,
});
const galleries = rawGalleries as unknown as GalleryEntry[];

if (Astro.cache?.enabled) {
	Astro.cache.set(cacheHint);
}
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getPublicCopy(currentLocale);

const photoGalleries = galleries.filter((g) => g.data.gallery_type === "photo");
const videoGalleries = galleries.filter((g) => g.data.gallery_type === "video");
const mixedGalleries = galleries.filter((g) => g.data.gallery_type === "mixed");

function getItemsCount(gallery: (typeof galleries)[number]) {
	const items = gallery.data.gallery_items;
	return Array.isArray(items) ? items.length : 0;
}

function getTypeBadgeClass(type: string) {
	if (type === "photo") return "badge-photo";
	if (type === "video") return "badge-video";
	return "badge-mixed";
}

function getTypeLabel(type: string) {
	if (type === "photo") return copy.galleryFilterPhoto;
	if (type === "video") return copy.galleryFilterVideo;
	return copy.galleryFilterMixed;
}
---

<BaseLayout
	title={copy.galleryTitle}
	description={copy.galleryDescription}
	showFooterWidgets={false}
>
	<!-- Hero Section -->
	<section class="gallery-hero">
		<p class="kicker">{copy.galleryKicker}</p>
		<h1 class="gallery-hero__heading">{copy.galleryListHeading}</h1>
		<p class="gallery-hero__intro">{copy.galleryListIntro}</p>
		<div class="gallery-hero__stats">
			<div class="stat-chip">
				<span class="stat-chip__icon">🖼️</span>
				<span>{photoGalleries.length} {copy.galleryFilterPhoto}</span>
			</div>
			<div class="stat-chip">
				<span class="stat-chip__icon">🎬</span>
				<span>{videoGalleries.length} {copy.galleryFilterVideo}</span>
			</div>
			<div class="stat-chip">
				<span class="stat-chip__icon">✨</span>
				<span>{mixedGalleries.length} {copy.galleryFilterMixed}</span>
			</div>
		</div>
	</section>

	<!-- Gallery Grid -->
	{galleries.length === 0 ? (
		<section class="gallery-empty">
			<div class="gallery-empty__icon">🖼️</div>
			<h2 class="gallery-empty__title">{copy.noGalleryYet}</h2>
			<p class="gallery-empty__desc">{currentLocale.startsWith("id") ? "Konten galeri akan segera tersedia. Silakan kunjungi kembali." : "Gallery content will be available soon. Please check back later."}</p>
		</section>
	) : (
		<section class="gallery-grid-section">
			<div class="gallery-grid" id="gallery-grid">
				{galleries.map((gallery) => (
					<a
						class="gallery-card"
						href={toLocalePath(`/gallery/${resolveEntrySlug(gallery)}`, currentLocale, localeOptions)}
						data-astro-prefetch="hover"
						data-gallery-type={gallery.data.gallery_type || "mixed"}
					>
						<div class="gallery-card__cover">
							{gallery.data.cover_image ? (
								<Image
									image={asImage(gallery.data.cover_image)}
									class="gallery-card__img"
									alt={gallery.data.title || "Gallery"}
								/>
							) : (
								<div class="gallery-card__placeholder">
									{gallery.data.gallery_type === "video" ? "🎬" : "🖼️"}
								</div>
							)}
							<div class="gallery-card__overlay">
								<span class={`gallery-card__type-badge ${getTypeBadgeClass(gallery.data.gallery_type || "mixed")}`}>
									{getTypeLabel(gallery.data.gallery_type || "mixed")}
								</span>
								<span class="gallery-card__items-count">
									{copy.galleryItemsCount(getItemsCount(gallery))}
								</span>
							</div>
						</div>
						<div class="gallery-card__body">
							<h2 class="gallery-card__title">{gallery.data.title}</h2>
							{gallery.data.description && (
								<p class="gallery-card__desc">{gallery.data.description}</p>
							)}
							<div class="gallery-card__meta">
								{gallery.data.event_date && (
									<span class="gallery-card__meta-item">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
										{new Date(gallery.data.event_date).toLocaleDateString(currentLocale, { year: "numeric", month: "long", day: "numeric" })}
									</span>
								)}
								{gallery.data.location && (
									<span class="gallery-card__meta-item">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
										{gallery.data.location}
									</span>
								)}
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.gallery-hero {
		text-align: center;
		padding: 3rem 2rem 2rem;
	}

	.gallery-hero__heading {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 800;
		margin: 0 auto 1rem;
		max-width: 44rem;
		line-height: 1.15;
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		letter-spacing: -0.02em;
	}

	.gallery-hero__intro {
		max-width: 40rem;
		margin: 0 auto 2rem;
		font-size: 1.05rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.gallery-hero__stats {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.stat-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 1rem;
		background: var(--surface-main);
		border: 1px solid var(--surface-border);
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--text-muted);
		box-shadow: var(--shadow-sm);
	}

	.stat-chip__icon {
		font-size: 1rem;
	}

	/* Gallery Grid Section */
	.gallery-grid-section {
		padding: 0;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}

	/* Gallery Card */
	.gallery-card {
		display: flex;
		flex-direction: column;
		background: var(--gradient-surface);
		border: 1px solid var(--surface-border);
		border-radius: 1.25rem;
		overflow: hidden;
		text-decoration: none;
		color: var(--text-main);
		box-shadow: var(--shadow-sm);
		transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
		position: relative;
	}

	.gallery-card:hover {
		transform: translateY(-6px);
		box-shadow: var(--shadow-xl);
		border-color: rgba(99, 102, 241, 0.3);
	}

	.gallery-card__cover {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(217,70,239,0.08));
	}

	.gallery-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.gallery-card:hover .gallery-card__img {
		transform: scale(1.06);
	}

	.gallery-card__placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 3.5rem;
		opacity: 0.6;
	}

	.gallery-card__overlay {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 0.75rem 1rem;
		background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 100%);
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 0.5rem;
	}

	.gallery-card__type-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.badge-photo {
		background: rgba(14, 165, 233, 0.85);
		color: #ffffff;
	}

	.badge-video {
		background: rgba(217, 70, 239, 0.85);
		color: #ffffff;
	}

	.badge-mixed {
		background: rgba(99, 102, 241, 0.85);
		color: #ffffff;
	}

	.gallery-card__items-count {
		font-size: 0.8rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.9);
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
	}

	.gallery-card__body {
		padding: 1.25rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.gallery-card__title {
		font-size: 1.1rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.3;
		color: var(--text-main);
	}

	.gallery-card:hover .gallery-card__title {
		color: var(--accent);
	}

	.gallery-card__desc {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.gallery-card__meta {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		margin-top: auto;
		padding-top: 0.75rem;
		border-top: 1px solid var(--surface-border);
	}

	.gallery-card__meta-item {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	/* Empty state */
	.gallery-empty {
		text-align: center;
		padding: 4rem 2rem;
	}

	.gallery-empty__icon {
		font-size: 4rem;
		margin-bottom: 1.5rem;
		opacity: 0.5;
	}

	.gallery-empty__title {
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0 0 0.75rem;
		color: var(--text-muted);
	}

	.gallery-empty__desc {
		font-size: 1rem;
		color: var(--text-muted);
		margin: 0;
	}

	@media (max-width: 640px) {
		.gallery-grid {
			grid-template-columns: 1fr;
		}

		.gallery-hero {
			padding: 2rem 1.25rem 1.5rem;
		}
	}
</style>
