---
import { getSiteSettings, getI18nConfig } from "emdash";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicCopy } from "../utils/public-copy";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

// Fetch SIKESRA public aggregates
const url = new URL("/_emdash/api/plugins/awcms-micro-sikesra/public/status", Astro.url.origin);
interface SikesraPublicCategory {
	code: string;
	label: string;
	total: number;
	verified: number;
	suppressed: boolean;
}

interface SikesraData {
	status: string;
	governanceMode: string;
	publicAggregate: {
		categories: SikesraPublicCategory[];
		caveat: string;
	};
}

const fallbackSikesraData: SikesraData = {
	status: "unavailable",
	governanceMode: "public-safe fallback",
	publicAggregate: {
		categories: [],
		caveat: "Public aggregate status is temporarily unavailable."
	}
};
let sikesraData: SikesraData = fallbackSikesraData;
let sikesraFetchFailed = false;

const isRecord = (value: unknown): value is Record<string, unknown> =>
	typeof value === "object" && value !== null && !Array.isArray(value);
const clampPublicCount = (value: unknown) => Math.max(0, Number.isFinite(Number(value)) ? Number(value) : 0);
const normalizeSikesraData = (value: unknown): SikesraData => {
	if (!isRecord(value)) return fallbackSikesraData;
	const aggregate = isRecord(value.publicAggregate) ? value.publicAggregate : null;
	const rawCategories = Array.isArray(aggregate?.categories) ? aggregate.categories : [];
	return {
		status: typeof value.status === "string" ? value.status : fallbackSikesraData.status,
		governanceMode: typeof value.governanceMode === "string" ? value.governanceMode : fallbackSikesraData.governanceMode,
		publicAggregate: {
			caveat: typeof aggregate?.caveat === "string" ? aggregate.caveat : fallbackSikesraData.publicAggregate.caveat,
			categories: rawCategories.filter(isRecord).map((category) => {
				const suppressed = category.suppressed === true;
				return {
					code: typeof category.code === "string" ? category.code : "unknown",
					label: typeof category.label === "string" ? category.label : "Unknown",
					total: suppressed ? 0 : clampPublicCount(category.total),
					verified: suppressed ? 0 : clampPublicCount(category.verified),
					suppressed,
				};
			}),
		},
	};
};

try {
	const res = await fetch(url);
	if (res.ok) {
		sikesraData = normalizeSikesraData(await res.json());
	} else {
		sikesraFetchFailed = true;
	}
} catch (err) {
	sikesraFetchFailed = true;
	console.error("Failed to fetch SIKESRA status:", err);
}

resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;

const copy = getPublicCopy(currentLocale);
const maxVal = Math.max(...(sikesraData.publicAggregate?.categories?.map(c => c.total) || []), 1);
const hasSikesraCategories = sikesraData.publicAggregate?.categories?.length > 0;
const displayStatus = sikesraFetchFailed ? copy.sikesraStatusUnavailable : sikesraData.status;
const displayGovernanceMode = sikesraFetchFailed ? copy.sikesraGovernanceFallback : sikesraData.governanceMode;
const displayCaveat = sikesraFetchFailed ? copy.sikesraUnavailableDescription : sikesraData.publicAggregate?.caveat;
---

<BaseLayout title={copy.sikesraRecapitulationTitle} description={copy.sikesraRecapitulationDescription} showFooterWidgets={false}>
	<section class="card" style="margin-bottom:2rem;">
		<p class="kicker">{copy.sikesraRecapitulationKicker}</p>
		<h1 style="font-size:clamp(2.25rem,5vw,3.5rem);margin:0 0 1rem;">{copy.sikesraRecapitulationHeading}</h1>
		<p style="color:var(--text-muted);margin-bottom:1.5rem;font-size:1.1rem;">{copy.sikesraRecapitulationIntro}</p>
		<div style="display:flex;gap:1.5rem;flex-wrap:wrap;font-size:0.9rem;border-top:1px solid rgba(15,23,42,0.08);padding-top:1rem;">
			<div>
				<strong>{copy.sikesraSystemStatus}:</strong> <span style="text-transform:uppercase;color:var(--accent);font-weight:600;">{displayStatus}</span>
			</div>
			<div>
				<strong>{copy.sikesraGovernanceMode}:</strong> <span style="text-transform:capitalize;color:var(--accent);font-weight:600;">{displayGovernanceMode}</span>
			</div>
		</div>
	</section>

	<!-- Beautiful grouped horizontal bar chart -->
	{hasSikesraCategories ? (
		<section class="card" style="margin-bottom:2rem; padding: 2rem;">
			<h2 style="margin-top:0; font-size:1.5rem; font-weight:700; margin-bottom:0.5rem;">
				{copy.sikesraChartTitle}
			</h2>
			<p style="color:var(--text-muted); font-size:0.9rem; margin-bottom:2rem;">
				{copy.sikesraChartDescription}
			</p>
			
			<div style="display:flex; flex-direction:column; gap:1.5rem;">
				{sikesraData.publicAggregate.categories.map((cat) => {
					const totalPct = (cat.total / maxVal) * 100;
					const verifiedPct = (cat.verified / maxVal) * 100;
					const totalLabel = `${cat.label} ${copy.sikesraTotalEntities}: ${cat.total}`;
					const verifiedLabel = `${cat.label} ${copy.sikesraVerified}: ${cat.verified}`;
					
					return (
						<div style="display:flex; flex-direction:column; gap:0.5rem;" aria-label={cat.label}>
							<div style="display:flex; justify-content:space-between; align-items:center; font-weight:600; font-size:0.95rem;">
								<span>{cat.label}</span>
								{cat.suppressed ? (
									<span style="font-size:0.8rem; color:var(--text-muted); font-style:italic;">{copy.sikesraSuppressedText}</span>
								) : (
									<div style="display:flex; gap:1rem; font-size:0.8rem;">
										<span style="color:var(--primary); font-weight:700;">{copy.sikesraTotalShort}: {cat.total}</span>
										<span style="color:var(--accent); font-weight:700;">{copy.sikesraVerified}: {cat.verified}</span>
									</div>
								)}
							</div>
							
							{cat.suppressed ? (
								<div style="height:28px; width:100%; background:rgba(15,23,42,0.03); border:1px dashed rgba(15,23,42,0.12); border-radius:6px; display:flex; align-items:center; padding:0 12px; font-size:0.75rem; color:var(--text-muted);">
									{copy.sikesraLowCountPrivacy}
								</div>
							) : (
								<div style="display:flex; flex-direction:column; gap:6px;">
									<!-- Total Bar -->
									<div role="img" aria-label={totalLabel} style="width:100%; background:rgba(15,23,42,0.04); height:10px; border-radius:9999px; overflow:hidden;">
										<div style={`background:var(--primary); height:100%; border-radius:9999px; width:${totalPct}%;`} />
									</div>
									<!-- Verified Bar -->
									<div role="img" aria-label={verifiedLabel} style="width:100%; background:rgba(15,23,42,0.04); height:10px; border-radius:9999px; overflow:hidden;">
										<div style={`background:var(--accent); height:100%; border-radius:9999px; width:${verifiedPct}%;`} />
									</div>
								</div>
							)}
						</div>
					);
				})}
			</div>
			
			<div style="display:flex; gap:1.5rem; margin-top:2rem; padding-top:1.5rem; border-top:1px solid rgba(15,23,42,0.08); font-size:0.8rem; color:var(--text-muted);">
				<div style="display:flex; align-items:center; gap:0.5rem;">
					<span style="width:10px; height:10px; background:var(--primary); border-radius:9999px; display:inline-block;" />
					<span>{copy.sikesraTotalEntities}</span>
				</div>
				<div style="display:flex; align-items:center; gap:0.5rem;">
					<span style="width:10px; height:10px; background:var(--accent); border-radius:9999px; display:inline-block;" />
					<span>{copy.sikesraVerified}</span>
				</div>
			</div>
		</section>
	) : (
		<section class="card" style="margin-bottom:2rem;padding:2rem;">
			<h2 style="margin-top:0;font-size:1.5rem;font-weight:700;margin-bottom:0.5rem;">
				{sikesraFetchFailed ? copy.sikesraUnavailableTitle : copy.sikesraNoPublicDataTitle}
			</h2>
			<p style="color:var(--text-muted);font-size:0.95rem;margin-bottom:0;">
				{sikesraFetchFailed ? copy.sikesraUnavailableDescription : copy.sikesraNoPublicDataDescription}
			</p>
		</section>
	)}

	{hasSikesraCategories && <section class="card" style="margin-bottom:2rem;">
		<div style="display:grid;gap:1.5rem;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));">
			{sikesraData.publicAggregate?.categories?.map((cat) => (
				<div style="border:1px solid rgba(15,23,42,0.08);border-radius:1rem;padding:1.5rem;background:#fff;display:flex;flex-direction:column;justify-content:between;">
					<h3 style="margin:0 0 0.5rem;font-size:1.25rem;font-weight:700;">{cat.label}</h3>
					{cat.suppressed ? (
						<p style="color:var(--text-muted);font-size:0.87rem;font-style:italic;margin:auto 0 0;">{copy.sikesraSuppressedText}</p>
					) : (
						<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:auto;">
							<div>
								<span style="font-size:0.85rem;color:var(--text-muted);display:block;">{copy.sikesraTotalEntities}</span>
								<strong style="font-size:2rem;font-weight:800;color:var(--primary);">{cat.total}</strong>
							</div>
							<div>
								<span style="font-size:0.85rem;color:var(--text-muted);display:block;">{copy.sikesraVerified}</span>
								<strong style="font-size:2rem;font-weight:800;color:var(--accent);">{cat.verified}</strong>
							</div>
						</div>
					)}
				</div>
			))}
		</div>
	</section>}

	<section class="card">
		<h2 style="margin-top:0;">{copy.sikesraPrivacyNotice}</h2>
		<p style="color:var(--text-muted);line-height:1.6;margin-bottom:1rem;">{copy.sikesraPrivacyNoticeDescription}</p>
		<p style="color:var(--text-muted);font-size:0.9rem;font-style:italic;margin-bottom:0;">{displayCaveat}</p>
	</section>
</BaseLayout>
