---
import { getEmDashCollection, getI18nConfig } from "emdash";
import { Image } from "emdash/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveEntrySlug, toLocalePath } from "../../utils/locale-path";
import { getPublicCopy } from "../../utils/public-copy";

function asImage(value: unknown) {
	return value as any;
}

const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	locale: currentLocale,
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getPublicCopy(currentLocale);
const featuredPost = posts[0];
const remainingPosts = posts.slice(1);
---

<BaseLayout title={copy.postsTitle} description={copy.postsDescription} showFooterWidgets={false}>
	<section class="content-hero">
		<p class="kicker">{copy.homeKicker}</p>
		<h1>{copy.postsTitle}</h1>
		<p>{copy.postsDescription}</p>
		<div class="content-hero__meta">
			<span>{posts.length} {copy.counts.posts}</span>
			<a href="/_emdash/admin/content/posts">{copy.createPost}</a>
		</div>
	</section>

	{posts.length === 0 ? (
		<section class="card empty-state">
			<h2>{copy.noPostsYet}</h2>
			<p>{copy.noPostsCreateOne}</p>
		</section>
	) : (
		<>
			{featuredPost && (
				<section class="featured-story">
					<a href={toLocalePath(`/posts/${resolveEntrySlug(featuredPost)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
						<div class="featured-story__media">
							{featuredPost.data.featured_image ? (
								<Image image={asImage(featuredPost.data.featured_image)} class="featured-story__image" />
							) : (
								<span>{copy.postsTitle}</span>
							)}
						</div>
						<div class="featured-story__body">
							<span class="story-index">01</span>
							<h2>{featuredPost.data.title}</h2>
							{featuredPost.data.excerpt && <p>{featuredPost.data.excerpt}</p>}
						</div>
					</a>
				</section>
			)}

			<section class="story-grid">
				{remainingPosts.map((post, index) => (
					<article class="story-card">
						<a href={toLocalePath(`/posts/${resolveEntrySlug(post)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
							{post.data.featured_image && <Image image={asImage(post.data.featured_image)} class="story-card__image" />}
							<span class="story-index">0{index + 2}</span>
							<h2>{post.data.title}</h2>
						</a>
						{post.data.excerpt && <p>{post.data.excerpt}</p>}
					</article>
				))}
			</section>
		</>
	)}
</BaseLayout>

<style>
	.content-hero,
	.featured-story,
	.empty-state {
		border: 1px solid var(--surface-border);
		border-radius: 2rem;
		background: var(--gradient-surface);
		box-shadow: var(--shadow-lg);
	}

	.content-hero {
		padding: clamp(2rem, 6vw, 4.5rem);
		text-align: center;
	}

	.content-hero h1 {
		max-width: 12ch;
		margin: 0 auto 1rem;
		font-size: clamp(2.6rem, 7vw, 5rem);
		line-height: 0.98;
		letter-spacing: -0.07em;
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.content-hero p {
		max-width: 42rem;
		margin: 0 auto;
		color: var(--text-muted);
	}

	.content-hero__meta {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
	}

	.content-hero__meta span,
	.content-hero__meta a {
		padding: 0.55rem 0.95rem;
		border-radius: 999px;
		border: 1px solid var(--surface-border);
		background: var(--surface-main);
		font-weight: 800;
	}

	.featured-story a {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.85fr);
		color: var(--text-main);
	}

	.featured-story__media {
		min-height: 24rem;
		background: linear-gradient(135deg, rgba(99, 102, 241, 0.18), rgba(14, 165, 233, 0.14));
		display: grid;
		place-items: center;
		overflow: hidden;
	}

	.featured-story__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.featured-story__body {
		padding: clamp(1.5rem, 4vw, 3rem);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.featured-story h2,
	.story-card h2 {
		margin: 0.45rem 0 0.75rem;
		font-size: clamp(1.55rem, 3vw, 2.8rem);
		line-height: 1.05;
		letter-spacing: -0.04em;
	}

	.story-index {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.story-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.story-card {
		padding: 1.2rem;
		border: 1px solid var(--surface-border);
		border-radius: 1.5rem;
		background: var(--gradient-surface);
		transition: transform 0.2s ease, border-color 0.2s ease;
	}

	.story-card:hover {
		transform: translateY(-3px);
		border-color: var(--accent);
	}

	.story-card a {
		color: var(--text-main);
	}

	.story-card__image {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 1rem;
		margin-bottom: 1rem;
	}

	.featured-story p,
	.story-card p,
	.empty-state p {
		color: var(--text-muted);
	}

	.empty-state {
		padding: 2rem;
		text-align: center;
	}

	@media (max-width: 760px) {
		.featured-story a {
			grid-template-columns: 1fr;
		}
	}
</style>
