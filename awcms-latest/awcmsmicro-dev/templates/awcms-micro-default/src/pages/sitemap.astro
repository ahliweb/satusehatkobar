---
import { getEmDashCollection, getI18nConfig, getSiteSettings } from "emdash";
import BaseLayout from "../layouts/BaseLayout.astro";
import { resolveEntrySlug, toLocalePath } from "../utils/locale-path";
import { getPublicCopy } from "../utils/public-copy";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

function asString(v: unknown): string {
	return typeof v === "string" ? v : String(v ?? "");
}

function entryUrlSlug(entry: { id: string; data: unknown }): string {
	const slug = (entry as Record<string, unknown>).slug;
	return typeof slug === "string" && slug.length > 0 ? slug : resolveEntrySlug(entry);
}

const { siteTitle } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const localeOptions = { defaultLocale, locales: i18nConfig?.locales || ["en", "id"] };
const copy = getPublicCopy(currentLocale);

const [
	{ entries: posts },
	{ entries: newsItems },
	{ entries: pages },
	{ entries: services },
] = await Promise.all([
	getEmDashCollection("posts", { limit: 50, locale: currentLocale }),
	getEmDashCollection("news", { limit: 50, locale: currentLocale }),
	getEmDashCollection("pages", { limit: 50, locale: currentLocale }),
	getEmDashCollection("services", { limit: 50, locale: currentLocale }),
]);

const legalSlugs = new Set(["privacy", "terms", "aup", "sla", "perjanjian-layanan", "kebijakan-smki"]);
const infoSlugs = new Set(["about", "contact", "hiring", "knowledgebase", "payment"]);
const legalPages = pages.filter(p => legalSlugs.has(entryUrlSlug(p)));
const infoPages = pages.filter(p => infoSlugs.has(entryUrlSlug(p)));
---

<BaseLayout title={copy.sitemapTitle} description={copy.sitemapDescription} showFooterWidgets={false}>
	<section class="sitemap-page">
		<div class="sitemap-header">
			<p class="kicker">{siteTitle}</p>
			<h1>{copy.sitemapTitle}</h1>
			<p class="sitemap-lead">{copy.sitemapDescription}</p>
		</div>

		<div class="sitemap-grid">
			<div class="sitemap-section">
				<h2>{copy.sitemapSectionMain}</h2>
				<ul>
					<li><a href={toLocalePath("/", currentLocale, localeOptions)}>{copy.returnHome}</a></li>
					<li><a href={toLocalePath("/services", currentLocale, localeOptions)}>{copy.servicesTitle}</a></li>
					<li><a href={toLocalePath("/gallery", currentLocale, localeOptions)}>{copy.galleryTitle}</a></li>
					<li><a href={toLocalePath("/posts", currentLocale, localeOptions)}>{copy.postsTitle}</a></li>
					<li><a href={toLocalePath("/news", currentLocale, localeOptions)}>{copy.newsTitle}</a></li>
					<li><a href={toLocalePath("/testimonials", currentLocale, localeOptions)}>{copy.testimonialsTitle}</a></li>
					<li><a href={toLocalePath("/portfolio", currentLocale, localeOptions)}>{copy.portfolioTitle}</a></li>
					<li><a href={toLocalePath("/authors", currentLocale, localeOptions)}>{copy.authorsTitle}</a></li>
				</ul>
			</div>

			{infoPages.length > 0 && (
				<div class="sitemap-section">
					<h2>{copy.sitemapSectionInfo}</h2>
					<ul>
						{infoPages.map(p => (
							<li>
								<a href={toLocalePath(`/${entryUrlSlug(p)}`, currentLocale, localeOptions)}>
									{asString(p.data.title)}
								</a>
							</li>
						))}
					</ul>
				</div>
			)}

			{legalPages.length > 0 && (
				<div class="sitemap-section">
					<h2>{copy.sitemapSectionLegal}</h2>
					<ul>
						{legalPages.map(p => (
							<li>
								<a href={toLocalePath(`/${entryUrlSlug(p)}`, currentLocale, localeOptions)}>
									{asString(p.data.title)}
								</a>
							</li>
						))}
					</ul>
				</div>
			)}

			{services.length > 0 && (
				<div class="sitemap-section">
					<h2>{copy.sitemapSectionServices}</h2>
					<ul>
						{services.map(s => (
							<li>
								<a href={toLocalePath(`/services/${entryUrlSlug(s)}`, currentLocale, localeOptions)}>
									{asString(s.data.title)}
								</a>
							</li>
						))}
					</ul>
				</div>
			)}

			{posts.length > 0 && (
				<div class="sitemap-section">
					<h2>{copy.postsTitle}</h2>
					<ul>
						{posts.map(p => (
							<li>
								<a href={toLocalePath(`/posts/${entryUrlSlug(p)}`, currentLocale, localeOptions)}>
									{asString(p.data.title)}
								</a>
							</li>
						))}
					</ul>
				</div>
			)}

			{newsItems.length > 0 && (
				<div class="sitemap-section">
					<h2>{copy.newsTitle}</h2>
					<ul>
						{newsItems.map(n => (
							<li>
								<a href={toLocalePath(`/news/${entryUrlSlug(n)}`, currentLocale, localeOptions)}>
									{asString(n.data.title)}
								</a>
							</li>
						))}
					</ul>
				</div>
			)}
		</div>
	</section>
</BaseLayout>

<style>
	.sitemap-page {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem 0;
	}

	.sitemap-header {
		margin-bottom: 2.5rem;
	}

	.sitemap-header h1 {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		margin: 0.25rem 0 0.75rem;
	}

	.sitemap-lead {
		color: var(--text-muted);
		margin: 0;
	}

	.sitemap-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 2rem;
	}

	.sitemap-section h2 {
		font-size: 0.8rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.09em;
		color: var(--accent);
		margin: 0 0 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--surface-border);
	}

	.sitemap-section ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.sitemap-section a {
		font-size: 0.9rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.sitemap-section a:hover {
		color: var(--accent);
	}
</style>
