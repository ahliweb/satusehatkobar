msgctxt "heroTitle"
msgid "Build Anything on a Resilient Foundation"
msgstr "Bangun Apa Saja di Atas Fondasi yang Tangguh"

msgctxt "heroSubtitle"
msgid "AWCMS-Micro combines the absolute reliability of single-tenant architecture with the flexible extension model of EmDash. Fully integrated, zero core modifications, completely tenant-ready."
msgstr "AWCMS-Micro menggabungkan keandalan mutlak arsitektur single-tenant dengan model ekstensi EmDash yang fleksibel. Terintegrasi penuh, tanpa modifikasi core, siap untuk multi-tenant."

msgctxt "heroCtaPrimary"
msgid "Explore Admin"
msgstr "Jelajahi Admin"

msgctxt "heroCtaSecondary"
