{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "awcms-sskkobar-worker",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-05-14",
	"compatibility_flags": ["nodejs_compat"],
	"placement": { "mode": "smart" },
	"routes": [
		{
			"pattern": "awcms-sskobar.ahlikoding.com/*",
			"zone_name": "ahlikoding.com",
			"custom_domain": false
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "awcms-sskkobar-d1",
			"database_id": "REPLACE_WITH_SSKOBAR_PRODUCTION_D1_DATABASE_ID"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "awcms-sskkobar-r2"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "REPLACE_WITH_SSKOBAR_PRODUCTION_KV_NAMESPACE_ID"
		}
	],
	"images": {
		"binding": "IMAGES"
	},
	"worker_loaders": [
		{
			"binding": "LOADER"
		}
	],
	"vars": {
		"AWCMS_MICRO_SITE_URL": "https://awcms-sskobar.ahlikoding.com",
		"AWCMS_MICRO_STORAGE_PUBLIC_BASE_URL": "https://awcms-sskobar-s3.ahlikoding.com",
		"AWCMS_MICRO_GALLERY_MEDIA_STORAGE": "r2",
		"AWCMS_MICRO_GALLERY_CLOUDFLARE_IMAGES": "optional",
		"AWCMS_MICRO_GALLERY_CLOUDFLARE_STREAM": "optional"
	},
	"observability": {
		"enabled": true
	}
}
