# =============================================================================
# AWCMS-Micro Backup Configuration
# =============================================================================
# This file contains ALL backup and recovery settings in one place.
#
# SECURITY: This file MUST be encrypted before committing to any repository.
# Use: bash scripts/backup/encrypt-config.sh
# Decrypt: bash scripts/backup/decrypt-config.sh
#
# The encrypted file (.backup-config.age) is safe to store in private repos
# or cloud storage. NEVER commit this unencrypted file.
# =============================================================================

# ---------------------------------------------------------------------------
# GitLab Backup Repository (Private)
# ---------------------------------------------------------------------------
# Your GitLab account and repository for mirroring the codebase.
GITLAB_USERNAME="your-gitlab-username"
GITLAB_REPO_NAME="awcms-micro"
GITLAB_VISIBILITY="private"

# Optional GitLab personal access token for local API/auth workflows.
GITLAB_PAT="your-gitlab-pat-here"

GITLAB_REPO_URL="https://oauth2:${GITLAB_PAT}@gitlab.com/${GITLAB_USERNAME}/${GITLAB_REPO_NAME}.git"

# Legacy SSH key path for workflows that still need it.
# Not used by the PAT-based GitLab mirror workflow.
GITLAB_SSH_KEY_PATH="$HOME/.ssh/gitlab_mirror"

# ---------------------------------------------------------------------------
# GitHub Repository
# ---------------------------------------------------------------------------
GITHUB_REPO_URL="git@github.com:ahliweb/awcms-micro.git"
GITHUB_BRANCH="main"

# GitHub personal access token for local API/auth workflows.
# Store it here only because this file is encrypted before backup.
GITHUB_PAT="your-github-pat-here"

# ---------------------------------------------------------------------------
# GitHub Actions (Workflows)
# ---------------------------------------------------------------------------
GITHUB_ACTION_DEPLOY_WORKFLOW="deploy.yml"
GITHUB_ACTION_BACKUP_WORKFLOW="backup-automated.yml"
GITHUB_ACTION_MIRROR_WORKFLOW="mirror-to-gitlab.yml"
GITHUB_ACTION_DEPLOY_BRANCH="main"
GITHUB_ACTION_BACKUP_CRON="0 2 * * *"
GITHUB_ACTION_WORKER_TEMPLATE_PACKAGE="@awcms-micro/template-default-cloudflare"
GITHUB_ACTION_NODE_VERSION="22"
GITHUB_ACTION_PNPM_VERSION="11.1.3"

# ---------------------------------------------------------------------------
# Cloudflare R2 (Backup Storage)
# ---------------------------------------------------------------------------
# R2 bucket for storing encrypted backups (DB, env, dotfiles).
R2_BUCKET_NAME="awcms-micro-backups"
R2_REGION="auto"

# ---------------------------------------------------------------------------
# Cloudflare Deployment (Worker: awcms-micro)
# ---------------------------------------------------------------------------
CLOUDFLARE_WORKER_NAME="awcms-micro"
CLOUDFLARE_WORKER_MAIN="./src/worker.ts"
CLOUDFLARE_WORKER_COMPATIBILITY_DATE="2026-05-14"
CLOUDFLARE_WORKER_COMPATIBILITY_FLAGS=("nodejs_compat")
CLOUDFLARE_WORKER_PLACEMENT_MODE="smart"
CLOUDFLARE_WORKER_ROUTE_PATTERN="awcms-micro.ahlikoding.com/*"
CLOUDFLARE_WORKER_ZONE_NAME="ahlikoding.com"
CLOUDFLARE_WORKER_CUSTOM_DOMAIN=false
CLOUDFLARE_WORKER_OBSERVABILITY=true

CLOUDFLARE_WORKER_D1_BINDING="DB"
CLOUDFLARE_WORKER_D1_DATABASE_NAME="awcms-micro-d1"
CLOUDFLARE_WORKER_D1_DATABASE_ID="df3281e0-4066-4da8-8911-1a0ed60a4562"

CLOUDFLARE_WORKER_R2_BINDING="MEDIA"
CLOUDFLARE_WORKER_R2_BUCKET_NAME="awcms-micro-media"

CLOUDFLARE_WORKER_KV_BINDING="SESSION"
CLOUDFLARE_WORKER_KV_NAMESPACE_ID="7382419ae0194a10949290c9e69d0840"

CLOUDFLARE_WORKER_IMAGE_BINDING="IMAGES"
CLOUDFLARE_WORKER_LOADER_BINDING="LOADER"

CLOUDFLARE_WORKER_SITE_URL="https://awcms-micro.ahlikoding.com"
CLOUDFLARE_WORKER_STORAGE_PUBLIC_BASE_URL="https://awcms-micro-s3.ahlikoding.com"

# Cloudflare credentials for wrangler CLI
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"

# ---------------------------------------------------------------------------
# Cloudflare D1 (Database)
# ---------------------------------------------------------------------------
# D1 database name to backup.
D1_DATABASE_NAME="awcms-micro-db"

# Backup retention - how many backups to keep
D1_BACKUP_KEEP_COUNT=7

# ---------------------------------------------------------------------------
# Encryption Settings
# ---------------------------------------------------------------------------
# Master passphrase for all encrypted backups.
# IMPORTANT: Store this in your password manager (1Password, Bitwarden, etc.)
BACKUP_PASSPHRASE="your-secure-master-passphrase-min-8-chars"

# Encryption tool: age (recommended) or gpg
ENCRYPTION_TOOL="age"

# ---------------------------------------------------------------------------
# Backup Schedule
# ---------------------------------------------------------------------------
# How often to run automated backups (cron format).
# Default: daily at 2 AM UTC
BACKUP_CRON_SCHEDULE="0 2 * * *"

# What to backup on each run: database, env, dotfiles, all
BACKUP_CONTENT="all"

# ---------------------------------------------------------------------------
# Dotfiles to Backup
# ---------------------------------------------------------------------------
# Additional dotfiles beyond the defaults.
# One path per line, relative to $HOME.
EXTRA_DOTFILES=(
    # ".config/kitty/kitty.conf"
    # ".config/wezterm/wezterm.lua"
    # ".local/share/nvim/lazy-lock.json"
)

# Include SSH keys in backup? (true/false)
BACKUP_SSH_KEYS=true

# Include GPG keys in backup? (true/false)
BACKUP_GPG_KEYS=false

# Include cloud credentials? (true/false)
BACKUP_CLOUD_CREDS=true

# ---------------------------------------------------------------------------
# Notification Settings
# ---------------------------------------------------------------------------
# How to get notified about backup results.
# Options: none, email, discord, slack
NOTIFICATION_METHOD="none"

# Discord webhook URL (if using discord notifications)
DISCORD_WEBHOOK_URL=""

# ---------------------------------------------------------------------------
# Local Paths
# ---------------------------------------------------------------------------
# Where to store local backup archives before uploading.
LOCAL_BACKUP_DIR="/tmp/awcms-backups"

# Log file for backup operations
BACKUP_LOG_FILE="$HOME/.awcms-backup.log"
